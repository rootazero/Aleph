{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aleph",
  "version": "0.1.0",
  "identifier": "com.aleph.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "halo",
        "title": "",
        "url": "about:blank",
        "width": 800,
        "height": 80,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "focus": false
      },
      {
        "label": "settings",
        "title": "Aleph Settings",
        "url": "about:blank",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500,
        "visible": false,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:*; script-src 'self' 'wasm-unsafe-eval' 'unsafe-inline' http://127.0.0.1:*; img-src 'self' data: https: http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https://*.openai.com https://*.anthropic.com https://*.googleapis.com; frame-src http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "AI-powered system assistant",
    "longDescription": "Aleph is a system-level AI middleware that brings AI intelligence directly to your cursor without context switching.",
    "copyright": "Copyright 2024 Aleph Team",
    "publisher": "Aleph",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./entitlements.plist",
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {}
}
