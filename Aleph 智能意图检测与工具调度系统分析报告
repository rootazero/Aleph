  统一置信度配置

  pub struct DispatcherConfig {
      /// L3 返回结果的最低置信度（低于此值视为无匹配）
      pub l3_min_confidence: f32,  // 默认 0.3

      /// 触发用户确认的置信度阈值（低于此值需要确认）
      pub confirmation_threshold: f32,  // 默认 0.7

      /// 自动执行的置信度阈值（高于此值直接执行）
      pub auto_execute_threshold: f32,  // 默认 0.9
  }

  // 明确关系：
  // confidence < l3_min_confidence → No match
  // l3_min_confidence <= confidence < confirmation_threshold → Needs confirmation
  // confirmation_threshold <= confidence < auto_execute_threshold → Optional confirmation
  // confidence >= auto_execute_threshold → Auto execute

