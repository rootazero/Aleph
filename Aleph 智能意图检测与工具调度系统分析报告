  5. 优化建议

  5.1 高优先级（立即修复）

  修复 JSON 解析漏洞

  // 使用括号匹配而非贪心搜索
  fn find_matching_brace(s: &str, start: usize) -> Option<usize> {
      let mut depth = 0;
      for (i, ch) in s[start..].char_indices() {
          match ch {
              '{' => depth += 1,
              '}' => {
                  depth -= 1;
                  if depth == 0 {
                      return Some(start + i);
                  }
              }
              _ => {}
          }
      }
      None
  }

  添加 Prompt 注入防护

  fn sanitize_for_prompt(input: &str) -> String {
      input
          .replace("```", "\\`\\`\\`")
          .replace("[SYSTEM]", "")
          .replace("[TASK]", "")
          .replace("[USER INPUT]", "")
          .replace("\n\n---\n\n", " ")
          .trim()
          .to_string()
  }

  // 在 L3Router.route() 中使用
  let sanitized_input = sanitize_for_prompt(input);
  let user_prompt = format!("[USER INPUT]\n{}\n...", sanitized_input);

  统一 JSON 提取逻辑

  // 创建单一的 JSON 提取函数供所有模块使用
  pub fn extract_json_robust(response: &str) -> Option<serde_json::Value> {
      // 1. 直接解析
      if let Ok(v) = serde_json::from_str(response.trim()) {
          return Some(v);
      }

      // 2. 从代码块提取
      if let Some(json_str) = extract_from_code_block(response) {
          if let Ok(v) = serde_json::from_str(&json_str) {
              return Some(v);
          }
      }

      // 3. 括号匹配提取
      if let Some(start) = response.find('{') {
          if let Some(end) = find_matching_brace(response, start) {
              if let Ok(v) = serde_json::from_str(&response[start..=end]) {
                  return Some(v);
              }
          }
      }

      None
  }

