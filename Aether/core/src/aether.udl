// UniFFI interface definition for Aether
//
// This file defines the FFI boundary between Rust and native clients (Swift, Kotlin, C#).
// UniFFI will automatically generate type-safe bindings from this definition.

namespace aether {
  // First-run initialization functions

  // Check if this is a fresh installation
  [Throws=AetherException]
  boolean is_fresh_install();

  // Run first-time initialization with progress callback
  [Throws=AetherException]
  void run_first_time_init(InitializationProgressHandler? progress_handler);

  // MEMORY MODULE MANAGEMENT

  // Check if embedding model files exist and are valid
  [Throws=AetherException]
  boolean check_embedding_model_exists();

  // Download embedding model files with progress callback
  // Returns true if download succeeded, false otherwise
  [Throws=AetherException]
  boolean download_embedding_model_standalone(InitializationProgressHandler? progress_handler);

  // SKILLS MODULE MANAGEMENT (add-skills-capability)

  // Get the skills directory path (~/.config/aether/skills)
  [Throws=AetherException]
  string get_skills_dir_string();

  // Initialize built-in skills (copy from bundle to user directory)
  // Never overwrites existing user skills
  [Throws=AetherException]
  void initialize_builtin_skills_ffi(string bundle_skills_dir);

  // List all installed skills
  [Throws=AetherException]
  sequence<SkillInfo> list_installed_skills();

  // Delete a skill by ID
  [Throws=AetherException]
  void delete_skill(string skill_id);

  // Install a skill from a GitHub URL (e.g., https://github.com/user/repo)
  // Returns the installed skill info
  [Throws=AetherException]
  SkillInfo install_skill_from_url(string url);

  // Install skills from a local ZIP file path
  // Returns list of installed skill IDs
  [Throws=AetherException]
  sequence<string> install_skills_from_zip(string zip_path);
};

// Processing states for Aether system
enum ProcessingState {
  "Idle",
  "Listening",
  "RetrievingMemory",    // Phase 7 - Task 7.5: Retrieving memories from database
  "ProcessingWithAI",    // Phase 7 - Task 7.5: AI provider is processing the request
  "Processing",          // Generic processing (kept for backward compatibility)
  "Typewriting",         // Phase 7.2: Typewriter animation in progress
  "Success",
  "Error"
};

// Log level enumeration (Phase 7.3 - Logging System)
enum LogLevel {
  "Error",     // Only errors
  "Warn",      // Warnings and errors
  "Info",      // Info, warnings, and errors (default)
  "Debug",     // Debug and above (verbose)
  "Trace"      // All logs (very verbose)
};

// Command type for command completion system (add-command-completion-system)
enum CommandType {
  "Action",     // Execute immediately (has capabilities like search)
  "Prompt",     // Load system prompt, await user input
  "Namespace"   // Container with child commands (e.g., /mcp)
};

// ===== PHANTOM FLOW INTERACTION (add-phantom-flow-interaction) =====

// Clarification request type
enum ClarificationType {
  "Select",   // Option list (menu-driven selection)
  "Text"      // Free-form text input
};

// A single option in a select-type clarification
dictionary ClarificationOption {
  string label;          // Display label for the option
  string value;          // Value to return when selected
  string? description;   // Optional description for additional context
};

// Request for user clarification through Halo overlay
dictionary ClarificationRequest {
  string id;                              // Unique request ID (for tracking/logging)
  string prompt;                          // Prompt text to display
  ClarificationType clarification_type;   // Type of clarification
  sequence<ClarificationOption>? options; // Options for select-type (None for text-type)
  string? default_value;                  // Default value (index as string for select, text for text-type)
  string? placeholder;                    // Placeholder text for text-type input
  string? source;                         // Source identifier (e.g., "skill:refine-text", "mcp:git")
};

// Result type for clarification response
enum ClarificationResultType {
  "Selected",   // User selected an option
  "TextInput",  // User entered text
  "Cancelled",  // User cancelled the request
  "Timeout"     // Request timed out
};

// Result of a clarification request
dictionary ClarificationResult {
  ClarificationResultType result_type;  // Type of result
  u32? selected_index;                   // Selected option index (for Select type)
  string? value;                         // Value (selected option value or text input)
};

// ===== END PHANTOM FLOW INTERACTION =====

// ===== MULTI-TURN CONVERSATION (add-multi-turn-conversation) =====

// A single turn in a conversation
dictionary ConversationTurn {
  u32 turn_id;           // Turn number within the session (0-indexed)
  string user_input;     // User's message
  string ai_response;    // AI's response
  i64 timestamp;         // Unix timestamp when turn was added
};

// ===== END MULTI-TURN CONVERSATION =====

// REMOVED: ImageFormat enum - image handling now in Swift layer (ClipboardManager)

// Error types for typed error handling
enum ErrorType {
  "Network",
  "Permission",
  "Quota",
  "Timeout",
  "Unknown"
};

// Error enum for UniFFI with message support
// UniFFI [Error] attribute will use the Display trait for error messages
[Error]
enum AetherException {
  "Error"
};

// Main interface for Aether core
interface AetherCore {
  // Constructor - creates new AetherCore with event handler
  [Throws=AetherException]
  constructor(AetherEventHandler handler);

  // REMOVED: System API methods (now handled by Swift layer)
  // - start_listening() / stop_listening() - handled by GlobalHotkeyMonitor
  // - get_clipboard_text() - handled by ClipboardManager
  // - has_clipboard_image() / read_clipboard_image() / write_clipboard_image() - handled by ClipboardManager
  // - is_listening() - no longer needed

  // AI PROCESSING METHODS
  // Process input with AI using the complete pipeline: Memory → Router → Provider → Storage
  // This is the main entry point for the new architecture
  [Throws=AetherException]
  string process_input(string user_input, CapturedContext context);

  // TEST METHODS (debug only - for Phase 3 development)
  // Simulate streaming AI response
  void test_streaming_response();

  // Simulate typed error
  void test_typed_error(ErrorType error_type, string message);

  // RETRY METHODS (Phase 3 - Error Handling)
  // Retry the last failed request with exponential backoff
  [Throws=AetherException]
  void retry_last_request();

  // Store request context for retry capability
  void store_request_context(string clipboard_content, string provider);

  // Clear stored request context
  void clear_request_context();

  // MEMORY MANAGEMENT METHODS (Phase 4 - Contextual Memory)

  // Get memory database statistics
  [Throws=AetherException]
  MemoryStats get_memory_stats();

  // Search memories by context
  [Throws=AetherException]
  sequence<MemoryEntry> search_memories(string app_bundle_id, string? window_title, u32 limit);

  // Get list of apps with memory counts (for UI filtering)
  [Throws=AetherException]
  sequence<AppMemoryInfo> get_memory_app_list();

  // Delete specific memory by ID
  [Throws=AetherException]
  void delete_memory(string id);

  // Clear memories (with optional filters)
  [Throws=AetherException]
  u64 clear_memories(string? app_bundle_id, string? window_title);

  // Get memory configuration
  MemoryConfig get_memory_config();

  // Update memory configuration
  [Throws=AetherException]
  void update_memory_config(MemoryConfig config);

  // Update general configuration (language preference, etc.)
  [Throws=AetherException]
  void update_general_config(GeneralConfig config);

  // Set current context (called from Swift when hotkey pressed)
  void set_current_context(CapturedContext context);

  // Store interaction memory with current context
  [Throws=AetherException]
  string store_interaction_memory(string user_input, string ai_output);

  // Retrieve memories and augment prompt with context (Phase 4 - Task 14)
  // This is the main entry point for integrating memory into AI request pipeline
  [Throws=AetherException]
  string retrieve_and_augment_prompt(string base_prompt, string user_input);

  // REMOVED: process_with_ai() - replaced by process_input()

  // Manually trigger memory cleanup
  [Throws=AetherException]
  u64 cleanup_old_memories();

  // MEMORY COMPRESSION METHODS (dual-layer memory architecture)

  // Manually trigger memory compression
  // Processes uncompressed memories, extracts facts using LLM, stores in memory_facts table
  [Throws=AetherException]
  CompressionResult trigger_compression();

  // Get compression statistics
  // Returns counts for raw memories, facts (total/valid), and breakdown by fact type
  [Throws=AetherException]
  CompressionStats get_compression_stats();

  // CONFIG MANAGEMENT METHODS (Phase 6 - Settings UI)

  // Load configuration from file
  [Throws=AetherException]
  FullConfig load_config();

  // Update provider configuration
  [Throws=AetherException]
  void update_provider(string name, ProviderConfig provider);

  // Delete provider configuration
  [Throws=AetherException]
  void delete_provider(string name);

  // Update routing rules
  [Throws=AetherException]
  void update_routing_rules(sequence<RoutingRuleConfig> rules);

  // Update shortcuts configuration
  [Throws=AetherException]
  void update_shortcuts(ShortcutsConfig shortcuts);

  // Update behavior configuration
  [Throws=AetherException]
  void update_behavior(BehaviorConfig behavior);

  // Update trigger configuration (hotkey-system-refactor)
  [Throws=AetherException]
  void update_trigger_config(TriggerConfig trigger);

  // Update search configuration
  [Throws=AetherException]
  void update_search_config(SearchConfig search);

  // Validate regex pattern
  [Throws=AetherException]
  boolean validate_regex(string pattern);

  // Test provider connection
  TestConnectionResult test_provider_connection(string provider_name);

  // Test provider connection with temporary configuration (without persisting to disk)
  TestConnectionResult test_provider_connection_with_config(string provider_name, ProviderConfig provider_config);

  // DEFAULT PROVIDER MANAGEMENT (Phase 3.3 - add-default-provider-selection)

  // Get the current default provider (returns None if no default or if disabled)
  string? get_default_provider();

  // Set the default provider (validates that provider exists and is enabled)
  [Throws=AetherException]
  void set_default_provider(string provider_name);

  // Get list of all enabled provider names (sorted alphabetically)
  sequence<string> get_enabled_providers();

  // REMOVED: Image clipboard methods - now handled by Swift ClipboardManager
  // - has_clipboard_image()
  // - read_clipboard_image()
  // - write_clipboard_image()

  // LOGGING CONTROL METHODS (Phase 7.3 - Logging System)

  // Get current log level
  LogLevel get_log_level();

  // Set log level dynamically
  [Throws=AetherException]
  void set_log_level(LogLevel level);

  // Get log directory path
  [Throws=AetherException]
  string get_log_directory();

  // SEARCH PROVIDER TESTING (integrate-search-registry)
  // Note: These are synchronous methods that use runtime.block_on() internally
  // to execute async search operations within Tokio runtime context
  [Throws=AetherException]
  ProviderTestResult test_search_provider(string provider_name);

  // Test search provider with ad-hoc config (without requiring saved config)
  // This allows testing provider credentials before saving to config file
  [Throws=AetherException]
  ProviderTestResult test_search_provider_with_config(SearchProviderTestConfig config);

  // COMMAND COMPLETION METHODS (add-command-completion-system)
  // These methods support the command completion UI for input assistance

  // Get all root-level commands for command completion UI
  // Returns commands parsed from config.toml routing rules with ^/ prefix
  sequence<CommandNode> get_root_commands();

  // Get children of a namespace command (e.g., /mcp)
  // Returns empty for most namespaces (MCP integration reserved for future)
  sequence<CommandNode> get_command_children(string parent_key);

  // Filter commands by key prefix (case-insensitive)
  // Used for autocomplete as user types (e.g., "se" matches "search", "settings")
  sequence<CommandNode> filter_commands(string prefix);

  // MULTI-TURN CONVERSATION METHODS (add-multi-turn-conversation)

  // Start a new conversation session
  // Returns the AI's response to the initial input
  [Throws=AetherException]
  string start_conversation(string initial_input, CapturedContext context);

  // Continue an existing conversation with follow-up input
  // Returns the AI's response to the follow-up input
  [Throws=AetherException]
  string continue_conversation(string follow_up_input);

  // End the current conversation session
  void end_conversation();

  // Check if there's an active conversation session
  boolean has_active_conversation();

  // Get the current turn count for the active conversation
  u32 conversation_turn_count();

  // MCP (Model Context Protocol) METHODS (implement-mcp-capability)

  // Get MCP configuration for Settings UI
  McpSettingsConfig get_mcp_config();

  // Update MCP configuration
  [Throws=AetherException]
  void update_mcp_config(McpSettingsConfig config);

  // Get list of MCP services
  sequence<McpServiceInfo> list_mcp_services();

  // Get list of MCP tools
  sequence<McpToolInfo> list_mcp_tools();
};

// Callback interface for events from Rust to client
callback interface AetherEventHandler {
  // Called when processing state changes
  void on_state_changed(ProcessingState state);

  // REMOVED: on_hotkey_detected() - hotkey handling now in Swift layer

  // Called when an error occurs
  void on_error(string message, string? suggestion);

  // NEW: Called when AI response chunk arrives (for streaming display)
  void on_response_chunk(string text);

  // NEW: Called when typed error occurs with error type
  void on_error_typed(ErrorType error_type, string message);

  // NEW: Called when progress update is available
  void on_progress(f32 percent);

  // AI PROCESSING CALLBACKS (Phase 7 - Task 7.4)
  // Called when AI processing starts with provider information
  void on_ai_processing_started(string provider_name, string provider_color);

  // Called when AI response is received with response preview
  void on_ai_response_received(string response_preview);

  // FALLBACK CALLBACK (Phase 10 - Task 10.2)
  // Called when primary provider fails and fallback is attempted
  void on_provider_fallback(string from_provider, string to_provider);

  // CONFIG HOT-RELOAD CALLBACK (Phase 6 - Task 6.1)
  // Called when config file changes externally
  void on_config_changed();

  // TYPEWRITER CALLBACKS (Phase 7.2 - Typewriter Output)
  // Called during typewriter animation with progress percentage (0.0-1.0)
  void on_typewriter_progress(f32 percent);

  // Called when typewriter animation is cancelled (Escape key or new hotkey)
  void on_typewriter_cancelled();

  // PHANTOM FLOW CALLBACKS (add-phantom-flow-interaction)
  // Called when clarification is needed from user
  // This is a blocking call - implementation must return result
  // Swift layer should show Halo clarification UI and wait for user response
  ClarificationResult on_clarification_needed(ClarificationRequest request);

  // MULTI-TURN CONVERSATION CALLBACKS (add-multi-turn-conversation)

  // Called when a new conversation session starts
  void on_conversation_started(string session_id);

  // Called when a conversation turn is completed
  void on_conversation_turn_completed(ConversationTurn turn);

  // Called when the AI response is ready and continuation input can be shown
  // The UI should display the Halo input box for user to continue the conversation
  void on_conversation_continuation_ready();

  // Called when a conversation session ends
  void on_conversation_ended(string session_id, u32 total_turns);
};

// Callback interface for first-time initialization progress
callback interface InitializationProgressHandler {
  // Called when initialization starts
  void on_init_started();

  // Called when a step begins
  void on_step_started(string step_name, u32 current, u32 total);

  // Called when download progress updates
  void on_download_progress(u64 downloaded_bytes, u64 total_bytes);

  // Called when a step completes
  void on_step_completed(string step_name);

  // Called when initialization completes successfully
  void on_init_completed();

  // Called when initialization fails
  void on_init_failed(string error);
};

// Configuration dictionaries
// Note: Config is not exposed as dictionary due to HashMap field
// Use AetherCore methods to access config instead

dictionary GeneralConfig {
  string? default_provider;
  u32 log_retention_days;
  boolean enable_performance_logging;
  string? language;
  boolean? show_command_hints;
};

dictionary MemoryConfig {
  boolean enabled;
  string embedding_model;
  u32 max_context_items;
  u32 retention_days;
  string vector_db;
  f32 similarity_threshold;
  sequence<string> excluded_apps;
  // AI-based memory retrieval settings
  boolean ai_retrieval_enabled;
  u64 ai_retrieval_timeout_ms;
  u32 ai_retrieval_max_candidates;
  u32 ai_retrieval_fallback_count;
  // Memory compression settings (dual-layer architecture)
  boolean compression_enabled;
  u32 compression_idle_timeout_seconds;
  u32 compression_turn_threshold;
  u32 compression_interval_seconds;
  u32 compression_batch_size;
  f32 conflict_similarity_threshold;
  u32 max_facts_in_context;
  u32 raw_memory_fallback_count;
};

// Provider configuration (Phase 6 - Task 1.5, Extended in refactor-provider-edit-panel)
dictionary ProviderConfig {
  string? provider_type;
  string? api_key;
  string model;
  string? base_url;
  string color;
  u64 timeout_seconds;
  boolean enabled;  // Whether the provider is active/enabled

  // Common generation parameters
  u32? max_tokens;
  f32? temperature;
  f32? top_p;
  u32? top_k;

  // OpenAI-specific parameters
  f32? frequency_penalty;
  f32? presence_penalty;

  // Claude/Gemini/Ollama-specific parameters
  string? stop_sequences;

  // Gemini-specific parameters
  string? thinking_level;
  string? media_resolution;

  // Ollama-specific parameters
  f32? repeat_penalty;

  // System prompt handling mode
  // "system" (default): Use separate system message
  // "prepend": Prepend system prompt to user message (for APIs that ignore system role)
  string? system_prompt_mode;
};

// Test connection result (for provider connection testing)
dictionary TestConnectionResult {
  boolean success;
  string message;
};

// Provider test result for search providers (add-search-settings-ui)
dictionary ProviderTestResult {
  boolean success;
  u32 latency_ms;
  string error_message;
  string error_type;  // "auth", "network", "config", or empty if success
};

// Configuration for ad-hoc search provider testing (without saved config)
dictionary SearchProviderTestConfig {
  string provider_type;    // "tavily", "brave", "searxng", "google", "bing", "exa"
  string? api_key;         // API key (required for most providers)
  string? base_url;        // Base URL (required for SearXNG)
  string? engine_id;       // Engine ID (required for Google CSE)
};

// Routing rule configuration (Phase 6 - Task 1.5, refactor-routing-rule-logic)
//
// Aether supports two types of routing rules:
// - Command Rules: Start with ^/, first-match-stops, requires provider
// - Keyword Rules: Non-/ patterns, all-match, prompt only (uses default_provider)
dictionary RoutingRuleConfig {
  // ===== Rule Type (refactor-routing-rule-logic) =====
  string? rule_type;   // "command" or "keyword" (auto-detected if not specified)
  boolean is_builtin;  // Whether this is a builtin rule (read-only in Settings UI)

  // ===== Core fields =====
  string regex;        // Regex pattern to match user input
  string? provider;    // Provider name (required for command rules, ignored for keyword)
  string? system_prompt;  // System prompt to guide AI behavior
  boolean? strip_prefix;  // Strip matched prefix before sending to AI (default: true for command rules)

  // ===== Capability fields =====
  sequence<string>? capabilities;  // Required capabilities (e.g., ["memory", "search"])
  string? intent_type;              // Intent type identifier (e.g., "translation", "research")
  string? context_format;           // Context injection format (e.g., "markdown", "xml", "json")

  // ===== Skills fields (reserved) =====
  string? skill_id;          // Skills ID (e.g., "build-macos-apps")
  string? skill_version;     // Skills version (e.g., "1.0.0")
  string? workflow;          // Skills workflow definition (JSON string)
  string? tools;             // Skills tools list (JSON string array)
  string? knowledge_base;    // Skills knowledge base path

  // ===== Command Mode Display fields =====
  string? icon;              // SF Symbol name for command mode display
  string? hint;              // Short hint text for command mode (max ~80px width)
};

// Shortcuts configuration (Phase 6 - Task 4.2)
dictionary ShortcutsConfig {
  string summon;           // Legacy - not used in new trigger system
  string? cancel;
  string command_prompt;   // Command completion hotkey (e.g., "Command+Option+/")
};

// Behavior configuration (Phase 6 - Task 5.1)
dictionary BehaviorConfig {
  string input_mode;
  string output_mode;
  u32 typing_speed;
  boolean pii_scrubbing_enabled;
  boolean multi_turn_enabled;
};

// Trigger configuration (hotkey-system-refactor)
// Controls hotkeys for Replace and Append operations
dictionary TriggerConfig {
  string replace_hotkey;  // e.g., "DoubleTap+leftShift" - AI replaces original text
  string append_hotkey;   // e.g., "DoubleTap+rightShift" - AI appends after original text
};

// Search backend configuration (add-search-capability-integration)
dictionary SearchBackendConfig {
  string provider_type;
  string? api_key;
  string? base_url;
  string? engine_id;
};

// Search backend entry (name + config)
dictionary SearchBackendEntry {
  string name;
  SearchBackendConfig config;
};

// PII (Personally Identifiable Information) scrubbing configuration
// Migrated from behavior.pii_scrubbing_enabled to search.pii
// (integrate-search-registry)
dictionary PIIConfig {
  boolean enabled;
  boolean scrub_email;
  boolean scrub_phone;
  boolean scrub_ssn;
  boolean scrub_credit_card;
};

// Search configuration (add-search-capability-integration)
// Note: This is a simplified view for UniFFI - backends HashMap is converted to sequence
dictionary SearchConfig {
  boolean enabled;
  string default_provider;
  sequence<string>? fallback_providers;
  u64 max_results;
  u64 timeout_seconds;
  sequence<SearchBackendEntry> backends;
  PIIConfig? pii;
};

// Smart matching configuration (semantic detection system)
// Controls multi-layer semantic matching with configurable thresholds
dictionary SmartMatchingConfig {
  boolean enabled;
  f64 command_confidence;
  f64 regex_threshold;
  f64 keyword_threshold;
  f64 ai_threshold;
  boolean enable_context_inference;
  sequence<ContextRuleConfig> context_rules;
  sequence<KeywordRuleConfig> keyword_rules;
};

// Context rule configuration for special matching behavior
dictionary ContextRuleConfig {
  string id;
  string condition_type;
  string? param_name;
  string? intent;
  sequence<string> bundle_ids;
  sequence<u8> hours;
  sequence<u8> days_of_week;
  string action_type;
  boolean use_input_as_value;
  string? capability;
  string? provider;
  string? system_prompt;
};

// Keyword rule configuration for weighted keyword matching
dictionary KeywordRuleConfig {
  string id;
  string? name;
  sequence<string> keywords;
  string match_mode;
  string intent_type;
  string? system_prompt;
  sequence<string> capabilities;
  f32? min_score;
};

// Skills configuration (add-skills-capability)
dictionary SkillsConfig {
  boolean enabled;           // Enable skills capability
  string skills_dir;         // Path to skills directory (relative to config dir or absolute)
  boolean auto_match_enabled;  // Enable auto-matching skills based on user input
};

// Skill information for UI display (add-skills-capability)
dictionary SkillInfo {
  string id;          // Skill ID (directory name)
  string name;        // Human-readable name from SKILL.md
  string description; // Description from SKILL.md
  sequence<string> allowed_tools;  // Allowed tools (if any)
};

// Full configuration (all settings combined)
dictionary FullConfig {
  string default_hotkey;
  GeneralConfig general;
  MemoryConfig memory;
  sequence<ProviderConfigEntry> providers;
  sequence<RoutingRuleConfig> rules;
  ShortcutsConfig? shortcuts;
  BehaviorConfig? behavior;
  SearchConfig? search;
  TriggerConfig? trigger;
  SmartMatchingConfig smart_matching;
  SkillsConfig? skills;  // Skills configuration (add-skills-capability)
};

// Provider config entry (name + config)
dictionary ProviderConfigEntry {
  string name;
  ProviderConfig config;
};

// Memory entry for a single interaction
dictionary MemoryEntry {
  string id;
  string app_bundle_id;
  string window_title;
  string user_input;
  string ai_output;
  i64 timestamp;
  f32? similarity_score;
};

// Memory database statistics
dictionary MemoryStats {
  u64 total_memories;
  u64 total_apps;
  f64 database_size_mb;
  i64 oldest_memory_timestamp;
  i64 newest_memory_timestamp;
};

// Compression result (returned by trigger_compression)
dictionary CompressionResult {
  u32 memories_processed;
  u32 facts_extracted;
  u32 facts_invalidated;
  u64 duration_ms;
};

// Compression statistics (returned by get_compression_stats)
dictionary CompressionStats {
  u64 total_raw_memories;
  u64 total_facts;
  u64 valid_facts;
  record<string, u64> facts_by_type;
};

// App memory info for UI filtering
dictionary AppMemoryInfo {
  string app_bundle_id;
  u64 memory_count;
};

// Captured context from active application
dictionary CapturedContext {
  string app_bundle_id;
  string? window_title;
  sequence<MediaAttachment>? attachments;  // Multimodal content support
};

// Media attachment for multimodal content (add-multimodal-content-support)
// Supports images, videos, and files from clipboard
dictionary MediaAttachment {
  string media_type;    // "image", "video", "file"
  string mime_type;     // "image/png", "image/jpeg", "video/mp4", etc.
  string data;          // Base64-encoded content
  string? filename;     // Optional original filename
  u64 size_bytes;       // Original size in bytes for logging/validation
};

// Command node for command completion UI (add-command-completion-system)
// Represents a command in the command tree (root or child)
dictionary CommandNode {
  string key;           // Unique identifier (e.g., "search", "en", "mcp")
  string description;   // Human-readable description for display
  string icon;          // SF Symbol name for visual representation
  string? hint;         // Short hint text (max ~80px width, localized)
  CommandType node_type;  // Action, Prompt, or Namespace
  boolean has_children; // Whether this node has child commands
  string? source_id;    // Optional source identifier (e.g., "rule:search", "mcp:git")
};

// ===== MCP (Model Context Protocol) Types (implement-mcp-capability) =====

// MCP service information for UI display
dictionary McpServiceInfo {
  string name;         // Service name (e.g., "fs", "git", "shell")
  string description;  // Service description
  boolean is_builtin;  // Whether this is a builtin service
  boolean is_running;  // Whether the service is currently running
  u32 tool_count;      // Number of tools provided by this service
};

// MCP tool information for UI display
dictionary McpToolInfo {
  string name;                    // Tool name (e.g., "fs:read_file", "git:status")
  string description;             // Tool description
  boolean requires_confirmation;  // Whether this tool requires user confirmation
  string service_name;            // Parent service name
};

// MCP configuration for Settings UI
dictionary McpSettingsConfig {
  boolean enabled;                    // MCP capability enabled
  boolean fs_enabled;                 // Filesystem service enabled
  boolean git_enabled;                // Git service enabled
  boolean shell_enabled;              // Shell service enabled
  boolean system_info_enabled;        // System info service enabled
  sequence<string> allowed_roots;     // Allowed filesystem roots
  sequence<string> allowed_repos;     // Allowed git repositories
  sequence<string> allowed_commands;  // Allowed shell commands
  u64 shell_timeout_seconds;          // Shell command timeout
};
