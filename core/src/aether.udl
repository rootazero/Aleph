// UniFFI interface definition for Aether
//
// This file defines the FFI boundary between Rust and native clients (Swift, Kotlin, C#).
// UniFFI will automatically generate type-safe bindings from this definition.

namespace aether {
  // Core interface initialization (rig-core based)
  [Throws=AetherFfiError]
  AetherCore init_core(string config_path, AetherEventHandler handler);

  // ===== UNIFIED INITIALIZATION (init_unified module) =====
  // Note: needs_first_time_init() and run_initialization() are defined via Rust proc-macros
  // in core/src/ffi/init.rs using #[uniffi::export]. They are automatically exported.
  // InitProgressHandlerFFI and InitResultFFI are also exported via proc-macros.

  // SKILLS MODULE MANAGEMENT (add-skills-capability)

  // Get the skills directory path (~/.aether/skills)
  [Throws=AetherException]
  string get_skills_dir_string();

  // Initialize built-in skills (copy from bundle to user directory)
  // Never overwrites existing user skills
  [Throws=AetherException]
  void initialize_builtin_skills_ffi(string bundle_skills_dir);

  // List all installed skills (read-only, no refresh needed)
  [Throws=AetherException]
  sequence<SkillInfo> list_installed_skills();

  // NOTE: Skill modification functions (delete, install) are in AetherCore
  // to ensure automatic tool registry refresh.
  // Use AetherCore.delete_skill(), AetherCore.install_skill(), etc.
};

// ===== VISION CAPABILITY (rust-native-vision) =====

// Capture mode for screen capture
enum CaptureMode {
  "Region",       // User-selected region
  "Window",       // Active window capture
  "FullScreen",   // Full screen capture
};

// Vision task type
enum VisionTask {
  "OcrOnly",          // Extract text only
  "OcrWithContext",   // Extract text + use as AI context
  "Describe",         // Image description
};

// Vision request from Swift to Rust
dictionary VisionRequest {
  sequence<u8> image_data;      // Raw PNG data
  CaptureMode capture_mode;
  VisionTask task;
  string? prompt;               // Optional user prompt for OcrWithContext
};

// Vision result from Rust to Swift
dictionary VisionResult {
  string extracted_text;        // OCR extracted text
  string? description;          // Image description (if requested)
  string? ai_response;          // AI response (OcrWithContext mode)
  f32 confidence;               // Confidence score (0.0-1.0)
  u64 processing_time_ms;       // Processing duration
};

// ===== END VISION CAPABILITY =====

// Processing states for Aether system
enum ProcessingState {
  "Idle",
  "Listening",
  "RetrievingMemory",    // Phase 7 - Task 7.5: Retrieving memories from database
  "ProcessingWithAI",    // Phase 7 - Task 7.5: AI provider is processing the request
  "Processing",          // Generic processing (kept for backward compatibility)
  "Typewriting",         // Phase 7.2: Typewriter animation in progress
  "Success",
  "Error"
};

// Log level enumeration (Phase 7.3 - Logging System)
enum LogLevel {
  "Error",     // Only errors
  "Warn",      // Warnings and errors
  "Info",      // Info, warnings, and errors (default)
  "Debug",     // Debug and above (verbose)
  "Trace"      // All logs (very verbose)
};

// Command type for command completion system (add-command-completion-system)
enum CommandType {
  "Action",     // Execute immediately (has capabilities like search)
  "Prompt",     // Load system prompt, await user input
  "Namespace"   // Container with child commands (e.g., /mcp)
};

// ===== PHANTOM FLOW INTERACTION (add-phantom-flow-interaction) =====

// Clarification request type
enum ClarificationType {
  "Select",      // Option list (menu-driven selection)
  "Text",        // Free-form text input
  "MultiGroup"   // Multiple question groups (each group is a single-select question)
};

// A single option in a select-type clarification
dictionary ClarificationOption {
  string label;          // Display label for the option
  string value;          // Value to return when selected
  string? description;   // Optional description for additional context
};

// A single question group for multi-group clarifications
dictionary QuestionGroup {
  string id;                              // Unique ID for this group (e.g., "yunsh", "font", "cipu")
  string prompt;                          // Question prompt (e.g., "请选择韵书（用于押韵与验证）")
  sequence<ClarificationOption> options;  // Options for this group
  u32? default_index;                     // Default selected index (0-based)
};

// Request for user clarification through Halo overlay
dictionary ClarificationRequest {
  string id;                              // Unique request ID (for tracking/logging)
  string prompt;                          // Prompt text to display (overall instruction for multi-group)
  ClarificationType clarification_type;   // Type of clarification
  sequence<ClarificationOption>? options; // Options for select-type (None for text-type or multi-group)
  sequence<QuestionGroup>? groups;        // Question groups for multi-group type (None for select/text)
  string? default_value;                  // Default value (index as string for select, text for text-type)
  string? placeholder;                    // Placeholder text for text-type input
  string? source;                         // Source identifier (e.g., "skill:refine-text", "mcp:git")
};

// Result type for clarification response
enum ClarificationResultType {
  "Selected",   // User selected an option
  "TextInput",  // User entered text
  "Cancelled",  // User cancelled the request
  "Timeout"     // Request timed out
};

// Result of a clarification request
dictionary ClarificationResult {
  ClarificationResultType result_type;    // Type of result
  u32? selected_index;                     // Selected option index (for Select type)
  string? value;                           // Value (selected option value or text input)
  record<string, string>? group_answers;  // Group answers for multi-group type (group_id -> selected_value)
};

// ===== END PHANTOM FLOW INTERACTION =====

// ===== MULTI-TURN CONVERSATION (add-multi-turn-conversation) =====

// A single turn in a conversation
dictionary ConversationTurn {
  u32 turn_id;           // Turn number within the session (0-indexed)
  string user_input;     // User's message
  string ai_response;    // AI's response
  i64 timestamp;         // Unix timestamp when turn was added
};

// ===== END MULTI-TURN CONVERSATION =====

// Error types for typed error handling
enum ErrorType {
  "Network",
  "Permission",
  "Quota",
  "Timeout",
  "Unknown"
};

// Error enum for UniFFI with message support
// UniFFI [Error] attribute will use the Display trait for error messages
[Error]
enum AetherException {
  "Error"
};

// Note: V1 AetherCore interface has been removed.
// Use AetherCore (rig-core based) for all functionality.

// ===== MCP STARTUP REPORT (Phase 3.3 - mcp-startup-feedback) =====

// Information about a failed MCP server
dictionary McpServerErrorFFI {
  string server_name;
  string error_message;
};

// Report of MCP server startup results
dictionary McpStartupReportFFI {
  sequence<string> succeeded_servers;
  sequence<McpServerErrorFFI> failed_servers;
};

// Note: V1 AetherEventHandler callback interface has been removed.
// Use AetherEventHandler for all event handling.

// ===== UNIFIED INITIALIZATION TYPES (init_unified module) =====
// Note: InitProgressHandlerFFI and InitResultFFI are defined via Rust proc-macros
// in core/src/ffi/init.rs using #[uniffi::export(callback_interface)] and #[uniffi::Record]
// They are automatically exported and available to Swift/Kotlin clients.
// ===== END UNIFIED INITIALIZATION TYPES =====

// Configuration dictionaries
// Note: Config is not exposed as dictionary due to HashMap field
// Use AetherCore methods to access config instead

dictionary GeneralConfig {
  string? default_provider;
  string? language;
  string? output_dir;
};

dictionary MemoryConfig {
  boolean enabled;
  string embedding_model;
  u32 max_context_items;
  u32 retention_days;
  string vector_db;
  f32 similarity_threshold;
  sequence<string> excluded_apps;
  // AI-based memory retrieval settings
  boolean ai_retrieval_enabled;
  u64 ai_retrieval_timeout_ms;
  u32 ai_retrieval_max_candidates;
  u32 ai_retrieval_fallback_count;
  // Memory compression settings (dual-layer architecture)
  boolean compression_enabled;
  u32 compression_idle_timeout_seconds;
  u32 compression_turn_threshold;
  u32 compression_interval_seconds;
  u32 compression_batch_size;
  f32 conflict_similarity_threshold;
  u32 max_facts_in_context;
  u32 raw_memory_fallback_count;
};

// Provider configuration (Phase 6 - Task 1.5, Extended in refactor-provider-edit-panel)
dictionary ProviderConfig {
  string? provider_type;
  string? api_key;
  string model;
  string? base_url;
  string color;
  u64 timeout_seconds;
  boolean enabled;  // Whether the provider is active/enabled

  // Common generation parameters
  u32? max_tokens;
  f32? temperature;
  f32? top_p;
  u32? top_k;

  // OpenAI-specific parameters
  f32? frequency_penalty;
  f32? presence_penalty;

  // Claude/Gemini/Ollama-specific parameters
  string? stop_sequences;

  // Gemini-specific parameters
  string? thinking_level;
  string? media_resolution;

  // Ollama-specific parameters
  f32? repeat_penalty;

  // System prompt handling mode
  // "system" (default): Use separate system message
  // "prepend": Prepend system prompt to user message (for APIs that ignore system role)
  string? system_prompt_mode;
};

// Test connection result (for provider connection testing)
dictionary TestConnectionResult {
  boolean success;
  string message;
};

// Provider test result for search providers (add-search-settings-ui)
dictionary ProviderTestResult {
  boolean success;
  u32 latency_ms;
  string error_message;
  string error_type;  // "auth", "network", "config", or empty if success
};

// Configuration for ad-hoc search provider testing (without saved config)
dictionary SearchProviderTestConfig {
  string provider_type;    // "tavily", "brave", "searxng", "google", "bing", "exa"
  string? api_key;         // API key (required for most providers)
  string? base_url;        // Base URL (required for SearXNG)
  string? engine_id;       // Engine ID (required for Google CSE)
};

// Routing rule configuration for builtin commands
//
// Aether supports two types of routing rules:
// - Command Rules: Start with ^/, first-match-stops, requires provider
// - Keyword Rules: Non-/ patterns, all-match, prompt only (uses default_provider)
dictionary RoutingRuleConfig {
  // ===== Rule Type =====
  string? rule_type;   // "command" or "keyword" (auto-detected if not specified)
  boolean is_builtin;  // Whether this is a builtin rule

  // ===== Core fields =====
  string regex;        // Regex pattern to match user input
  string? provider;    // Provider name (required for command rules, ignored for keyword)
  string? system_prompt;  // System prompt to guide AI behavior
  boolean? strip_prefix;  // Strip matched prefix before sending to AI (default: true for command rules)

  // ===== Capability fields =====
  sequence<string>? capabilities;  // Required capabilities (e.g., ["memory", "search"])
  string? intent_type;              // Intent type identifier (e.g., "translation", "research")
  string? preferred_model;          // Preferred model ID for Model Router (overrides automatic selection)
  string? context_format;           // Context injection format (e.g., "markdown", "xml", "json")

  // ===== Display fields =====
  string? icon;              // SF Symbol name for command mode display
};

// Shortcuts configuration (Phase 6 - Task 4.2)
dictionary ShortcutsConfig {
  string summon;           // Legacy - not used in new trigger system
  string? cancel;
  string command_prompt;   // Command completion hotkey (e.g., "Option+Space")
  string ocr_capture;      // OCR capture hotkey (e.g., "Command+Shift+Control+4")
};

// Behavior configuration for output mode and typing speed
dictionary BehaviorConfig {
  string output_mode;    // "typewriter" or "instant"
  u32 typing_speed;      // Characters per second for typewriter mode (10-200)
};

// Typo correction configuration (double-space trigger)
dictionary TypoCorrectionConfig {
  boolean enabled;           // Whether typo correction is enabled
  string? provider;          // Provider name (e.g., "openai", "gemini")
  string? model;             // Optional model override (e.g., "gpt-4o-mini")
  u64 timeout_seconds;       // Timeout for correction requests (default: 5)
  u64 max_length;            // Maximum text length to process (default: 2000)
};

// Trigger configuration (hotkey-system-refactor)
// Controls hotkeys for Replace and Append operations
dictionary TriggerConfig {
  string replace_hotkey;  // e.g., "DoubleTap+leftShift" - AI replaces original text
  string append_hotkey;   // e.g., "DoubleTap+rightShift" - AI appends after original text
};

// Search backend configuration (add-search-capability-integration)
dictionary SearchBackendConfig {
  string provider_type;
  string? api_key;
  string? base_url;
  string? engine_id;
};

// Search backend entry (name + config)
dictionary SearchBackendEntry {
  string name;
  SearchBackendConfig config;
};

// PII (Personally Identifiable Information) scrubbing configuration
// Migrated from behavior.pii_scrubbing_enabled to search.pii
// (integrate-search-registry)
dictionary PIIConfig {
  boolean enabled;
  boolean scrub_email;
  boolean scrub_phone;
  boolean scrub_ssn;
  boolean scrub_credit_card;
};

// Search configuration (add-search-capability-integration)
// Note: This is a simplified view for UniFFI - backends HashMap is converted to sequence
dictionary SearchConfig {
  boolean enabled;
  string default_provider;
  sequence<string>? fallback_providers;
  u64 max_results;
  u64 timeout_seconds;
  sequence<SearchBackendEntry> backends;
  PIIConfig? pii;
};

// Smart matching configuration (semantic detection system)
// Controls multi-layer semantic matching with configurable thresholds
dictionary SmartMatchingConfig {
  boolean enabled;
  f64 command_confidence;
  f64 regex_threshold;
  f64 keyword_threshold;
  f64 ai_threshold;
  boolean enable_context_inference;
  sequence<ContextRuleConfig> context_rules;
  sequence<KeywordRuleConfig> keyword_rules;
};

// Context rule configuration for special matching behavior
dictionary ContextRuleConfig {
  string id;
  string condition_type;
  string? param_name;
  string? intent;
  sequence<string> bundle_ids;
  sequence<u8> hours;
  sequence<u8> days_of_week;
  string action_type;
  boolean use_input_as_value;
  string? capability;
  string? provider;
  string? system_prompt;
};

// Keyword rule configuration for weighted keyword matching
dictionary KeywordRuleConfig {
  string id;
  string? name;
  sequence<string> keywords;
  string match_mode;
  string intent_type;
  string? system_prompt;
  sequence<string> capabilities;
  f32? min_score;
};

// Skills configuration (add-skills-capability)
dictionary SkillsConfig {
  boolean enabled;           // Enable skills capability
  string skills_dir;         // Path to skills directory (relative to config dir or absolute)
  boolean auto_match_enabled;  // Enable auto-matching skills based on user input
};

// Skill information for UI display (add-skills-capability)
dictionary SkillInfo {
  string id;          // Skill ID (directory name)
  string name;        // Human-readable name from SKILL.md
  string description; // Description from SKILL.md
  sequence<string> allowed_tools;  // Allowed tools (if any)
};

// Full configuration (all settings combined)
dictionary FullConfig {
  string default_hotkey;
  GeneralConfig general;
  MemoryConfig memory;
  sequence<ProviderConfigEntry> providers;
  sequence<RoutingRuleConfig> rules;
  ShortcutsConfig? shortcuts;
  BehaviorConfig? behavior;
  SearchConfig? search;
  TriggerConfig? trigger;
  SmartMatchingConfig smart_matching;
  SkillsConfig? skills;  // Skills configuration (add-skills-capability)
  PoliciesConfig policies;  // Mechanism-policy separation configuration
  TypoCorrectionConfig typo_correction;  // Typo correction configuration (double-space trigger)
};

// =============================================================================
// Policies Configuration (mechanism-policy separation)
// =============================================================================

// Root policies configuration
dictionary PoliciesConfig {
  ToolSafetyPolicy tool_safety;
  IntentDetectionPolicy intent;
  MemoryPolicies memory;
  RetryPolicy retry;
  WebFetchPolicy web_fetch;
  TextFormatPolicy text;
  MetricsPolicy metrics;
  KeywordPolicy keyword;
  ExperimentalPolicy experimental;
};

// Experimental feature flags
dictionary ExperimentalPolicy {
  boolean use_unified_intent_decider;
  boolean use_new_prompt_system;
  boolean verbose_decision_logging;
};

// Keyword matching policy for intent detection
dictionary KeywordPolicy {
  boolean enabled;
  f32 global_min_score;
  sequence<PolicyKeywordRule> rules;
};

// A keyword rule in policy config
dictionary PolicyKeywordRule {
  string id;
  string intent_type;
  sequence<PolicyWeightedKeyword> keywords;
  string match_mode;
  f32 min_score;
};

// Single keyword with weight for policy-based matching
dictionary PolicyWeightedKeyword {
  string word;
  f32 weight;
};

// Tool safety inference policy
dictionary ToolSafetyPolicy {
  sequence<string> high_risk_keywords;
  sequence<string> low_risk_keywords;
  sequence<string> reversible_keywords;
  sequence<string> readonly_keywords;
  string builtin_fallback;
  string native_fallback;
  string mcp_fallback;
  string skill_fallback;
  string custom_fallback;
};

// Intent detection policy
dictionary IntentDetectionPolicy {
  f64 confidence_threshold;
  u64 timeout_ms;
  u64 min_input_length;
  sequence<string> video_url_patterns;
};

// Memory policies container
dictionary MemoryPolicies {
  CompressionPolicy compression;
  AiRetrievalPolicy ai_retrieval;
};

// Compression scheduling policy
dictionary CompressionPolicy {
  u32 idle_timeout_seconds;
  u32 turn_threshold;
  u32 background_interval_seconds;
};

// AI-based memory retrieval policy
dictionary AiRetrievalPolicy {
  u64 timeout_ms;
  u32 max_candidates;
  u32 fallback_count;
  u64 content_truncate_length;
};

// Network retry policy
dictionary RetryPolicy {
  u32 max_retries;
  u64 initial_backoff_ms;
  f64 backoff_multiplier;
  u64 max_backoff_ms;
  sequence<u16> retryable_status_codes;
  boolean retry_on_timeout;
  boolean retry_on_network_error;
};

// Web fetch behavior policy
dictionary WebFetchPolicy {
  u64 max_content_length;
  u64 min_content_length;
  string user_agent;
  u64 timeout_seconds;
  boolean follow_redirects;
  u64 max_redirects;
  sequence<string> content_selectors;
};

// Text formatting policy
dictionary TextFormatPolicy {
  u64 default_truncate_length;
  u64 search_snippet_length;
  u64 mcp_result_length;
  u64 system_prompt_length;
  u64 user_message_length;
  string truncation_suffix;
};

// Performance metrics policy
dictionary MetricsPolicy {
  u64 target_hotkey_to_clipboard_ms;
  u64 target_clipboard_to_memory_ms;
  u64 target_memory_to_ai_ms;
  u64 target_ai_to_paste_ms;
  u64 target_paste_to_complete_ms;
  f64 warning_multiplier;
  boolean enable_logging;
  boolean enable_warnings;
};

// Provider config entry (name + config)
dictionary ProviderConfigEntry {
  string name;
  ProviderConfig config;
};

// Generation provider configuration (image/video/audio/speech)
dictionary GenerationProviderConfigFFI {
  string provider_type;          // Provider type identifier (openai, stability, elevenlabs, etc.)
  string? api_key;               // API key (optional, can use keychain)
  string? base_url;              // Base URL for API (optional, for self-hosted or proxy)
  string? model;                 // Default model to use
  boolean enabled;               // Whether this provider is enabled
  string color;                  // Brand color for UI theming (hex format)
  sequence<GenerationTypeFFI> capabilities;  // Supported generation types
  u64 timeout_seconds;           // Request timeout in seconds
};

// Memory entry for a single interaction
dictionary MemoryEntry {
  string id;
  string app_bundle_id;
  string window_title;
  string user_input;
  string ai_output;
  i64 timestamp;
  f32? similarity_score;
};

// Memory database statistics
dictionary MemoryStats {
  u64 total_memories;
  u64 total_apps;
  f64 database_size_mb;
  i64 oldest_memory_timestamp;
  i64 newest_memory_timestamp;
};

// Compression result (returned by trigger_compression)
dictionary CompressionResult {
  u32 memories_processed;
  u32 facts_extracted;
  u32 facts_invalidated;
  u64 duration_ms;
};

// Compression statistics (returned by get_compression_stats)
dictionary CompressionStats {
  u64 total_raw_memories;
  u64 total_facts;
  u64 valid_facts;
  record<string, u64> facts_by_type;
};

// App memory info for UI filtering
dictionary AppMemoryInfo {
  string app_bundle_id;
  u64 memory_count;
};

// Captured context from active application
dictionary CapturedContext {
  string app_bundle_id;
  string? window_title;
  sequence<MediaAttachment>? attachments;  // Multimodal content support
  string? topic_id;  // Topic ID for multi-turn conversations
};

// Media attachment for multimodal content (add-multimodal-content-support)
// Supports images, documents, videos, and files from clipboard
//
// Encoding field specifies data format:
// - "base64": Binary content encoded as Base64 (images, PDFs)
// - "utf8": Plain text content (markdown, txt, extracted text)
dictionary MediaAttachment {
  string media_type;    // "image", "document", "video", "file"
  string mime_type;     // "image/png", "text/markdown", "application/pdf", etc.
  string data;          // Content (format depends on `encoding` field)
  string encoding;      // "base64" | "utf8" - specifies data format
  string? filename;     // Optional original filename
  u64 size_bytes;       // Original size in bytes for logging/validation
};

// Command node for command completion UI (Flat Namespace Mode)
// In flat namespace mode, all commands are at root level.
// Tool source is indicated by source_type for badge display.
dictionary CommandNode {
  string key;             // Unique identifier (e.g., "search", "git", "refine-text")
  string description;     // Human-readable description for display
  string icon;            // SF Symbol name for visual representation
  string? hint;           // Short hint text (max ~80px width, localized)
  CommandType node_type;  // Action, Prompt, or Namespace (deprecated in flat namespace)
  boolean has_children;   // Whether this node has child commands (always false in flat namespace)
  string? source_id;      // Optional source identifier (e.g., "builtin:search", "mcp:git")
  ToolSourceType source_type;  // Tool source for UI badge display (flat namespace mode)
};

// ===== Dispatcher Layer Types (implement-dispatcher-layer) =====

// Tool source type for unified tool registry
enum ToolSourceType {
  "Native",   // Built-in native capabilities (Search, Video)
  "Builtin",  // System builtin commands (/search, /youtube, /webfetch)
  "Mcp",      // MCP server tool
  "Skill",    // Claude Agent Skill
  "Custom",   // User-defined custom command
};

// Unified tool representation for FFI
// All tools (Native, MCP, Skills, Custom, Builtin) are normalized to this structure
dictionary UnifiedToolInfo {
  string id;                    // Unique identifier (e.g., "native:search", "builtin:mcp")
  string name;                  // Command/tool name for invocation
  string display_name;          // Human-readable display name
  string description;           // Tool description
  ToolSourceType source_type;   // Tool source type
  string? source_id;            // Source-specific ID (server for MCP, skill ID for Skill)
  string? parameters_schema;    // JSON Schema string for input parameters
  boolean is_active;            // Whether tool is enabled
  boolean requires_confirmation; // Whether requires user confirmation
  string safety_level;          // Safety level label (Read Only, Reversible, Low Risk, High Risk)
  string? service_name;         // Parent service name (for MCP sub-tools)

  // UI Metadata (unify-tool-registry)
  string? icon;                 // SF Symbol icon name for UI display
  string? usage;                // Usage example (e.g., "/search <query>")
  string? localization_key;     // Localization key for i18n (e.g., "tool.search")
  boolean is_builtin;           // Whether this is a system builtin command
  i32 sort_order;               // Display sort order (lower = first)
  boolean has_subtools;         // Whether has dynamic subtools (e.g., /mcp, /skill)
};

// ===== MCP (Model Context Protocol) Types (implement-mcp-capability) =====

// MCP service information for UI display
dictionary McpServiceInfo {
  string name;         // Service name (e.g., "fs", "git", "shell")
  string description;  // Service description
  boolean is_builtin;  // Whether this is a builtin service
  boolean is_running;  // Whether the service is currently running
  u32 tool_count;      // Number of tools provided by this service
};

// MCP tool information for UI display
dictionary McpToolInfo {
  string name;                    // Tool name (e.g., "fs:read_file", "git:status")
  string description;             // Tool description
  boolean requires_confirmation;  // Whether this tool requires user confirmation
  string service_name;            // Parent service name
};

// MCP configuration for Settings UI
dictionary McpSettingsConfig {
  boolean enabled;                    // MCP capability enabled
  boolean fs_enabled;                 // Filesystem service enabled
  boolean git_enabled;                // Git service enabled
  boolean shell_enabled;              // Shell service enabled
  boolean system_info_enabled;        // System info service enabled
  sequence<string> allowed_roots;     // Allowed filesystem roots
  sequence<string> allowed_repos;     // Allowed git repositories
  sequence<string> allowed_commands;  // Allowed shell commands
  u64 shell_timeout_seconds;          // Shell command timeout
};

// ===== MCP Server Management Types (redesign-mcp-settings-ui) =====

// MCP server type (builtin or external)
enum McpServerType {
  "Builtin",   // Builtin service (Rust native implementation)
  "External",  // External server (user installed)
};

// MCP server status
enum McpServerStatus {
  "Stopped",    // Server is stopped
  "Starting",   // Server is starting
  "Running",    // Server is running
  "Error",      // Server has an error
};

// Environment variable key-value pair
dictionary McpEnvVar {
  string key;
  string value;
};

// MCP server permissions configuration
dictionary McpServerPermissions {
  boolean requires_confirmation;     // Whether this server requires user confirmation
  sequence<string> allowed_paths;    // Allowed file paths
  sequence<string> allowed_commands; // Allowed commands
};

// MCP server configuration (for both builtin and external servers)
dictionary McpServerConfig {
  string id;                          // Server unique identifier
  string name;                        // Server display name
  McpServerType server_type;          // Server type (builtin or external)
  boolean enabled;                    // Whether the server is enabled
  string? command;                    // Command to execute (external servers only)
  sequence<string> args;              // Command arguments
  sequence<McpEnvVar> env;            // Environment variables
  string? working_directory;          // Working directory
  string? trigger_command;            // Trigger command in Halo (e.g., /git for System Tools, /mcp/server for External)
  McpServerPermissions permissions;   // Server permissions
  string icon;                        // SF Symbol icon name
  string color;                       // Theme color (hex)
};

// MCP server status info (for UI display)
dictionary McpServerStatusInfo {
  McpServerStatus status;  // Current status
  string? message;         // Status message
  string? last_error;      // Last error message
};

// ===== DAG Task Plan Types (plan-confirmation-flow) =====

// Task display status for UI (DAG scheduler)
enum DagTaskDisplayStatus {
  "Pending",     // Task is waiting to be executed
  "Running",     // Task is currently running
  "Completed",   // Task completed successfully
  "Failed",      // Task failed
  "Cancelled",   // Task was cancelled
};

// Task information for UI display (DAG scheduler)
dictionary DagTaskInfo {
  string id;                    // Unique task identifier
  string name;                  // Human-readable task name
  DagTaskDisplayStatus status;  // Current status
  string risk_level;            // Risk level as a string ("low" or "high")
  sequence<string> dependencies; // IDs of tasks this task depends on
};

// Task execution plan for UI display (DAG scheduler)
dictionary DagTaskPlan {
  string id;                    // Unique plan identifier
  string title;                 // Human-readable plan title
  sequence<DagTaskInfo> tasks;  // List of tasks in the plan
  boolean requires_confirmation; // Whether user confirmation is required
};

// ===== Async Confirmation Flow Types (async-confirmation-flow) =====

// User's decision on a pending confirmation
// This is sent from Swift when user interacts with confirmation UI
enum UserConfirmationDecision {
  "Execute",          // Execute the tool as proposed
  "Cancel",           // Cancel and fall back to general chat
  "EditParameters",   // Edit parameters before execution (reserved for future)
};

// Pending confirmation information (FFI-safe)
// Contains all info needed for Swift to display confirmation UI
dictionary PendingConfirmationInfo {
  string id;                    // Unique confirmation ID (for resumption via confirm_action)
  string tool_id;               // Tool unique identifier (e.g., "native:search")
  string tool_name;             // Tool name/command (e.g., "search")
  string tool_display_name;     // Human-readable tool name
  string tool_description;      // Tool description
  string parameters_json;       // Parameters as JSON string
  f32 confidence;               // Confidence score (0.0-1.0)
  string reason;                // Reason for tool selection (from L3 routing)
  u64 timeout_ms;               // Timeout in milliseconds
};

// ===== GENERATION TYPES (media generation support) =====

// Generation type enum (image, video, audio, speech)
enum GenerationTypeFFI {
  "Image",   // Image generation (DALL-E, Stable Diffusion, etc.)
  "Video",   // Video generation (Runway, Pika, etc.)
  "Audio",   // Audio/music generation (Suno, MusicGen, etc.)
  "Speech",  // Text-to-speech synthesis (ElevenLabs, OpenAI TTS, etc.)
};

// Generation parameters for requests
dictionary GenerationParamsFFI {
  // Image/Video parameters
  u32? width;
  u32? height;
  string? aspect_ratio;
  string? quality;
  string? style;
  u32? n;
  i64? seed;
  string? format;

  // Video-specific
  f32? duration_seconds;
  u32? fps;

  // Audio/Speech parameters
  string? voice;
  f32? speed;
  string? language;

  // Common parameters
  string? model;
  string? negative_prompt;
  f32? guidance_scale;
  u32? steps;

  // Reference inputs
  string? reference_image;
  string? reference_audio;

  // Image editing - mask for inpainting (transparent areas = edit regions)
  string? mask;
};

// Generation data type enum
enum GenerationDataTypeFFI {
  "Bytes",      // Raw binary data
  "Url",        // URL to the generated content
  "LocalPath",  // Path to a local file
};

// Generation data container
dictionary GenerationDataFFI {
  GenerationDataTypeFFI data_type;
  sequence<u8>? bytes;
  string? url;
  string? local_path;
};

// Generation metadata
dictionary GenerationMetadataFFI {
  string? provider;
  string? model;
  u64? duration_ms;
  i64? seed;
  string? revised_prompt;
  string? content_type;
  u64? size_bytes;
  u32? width;
  u32? height;
  f32? duration_seconds;
};

// Generation output result
dictionary GenerationOutputFFI {
  GenerationTypeFFI generation_type;
  GenerationDataFFI data;
  sequence<GenerationDataFFI> additional_outputs;
  GenerationMetadataFFI metadata;
  string? request_id;
};

// Generation progress for long-running operations
dictionary GenerationProgressFFI {
  f32 percentage;
  string step;
  u64? eta_ms;
  boolean is_complete;
  string? preview_url;
};

// Generation provider info for listing
dictionary GenerationProviderInfoFFI {
  string name;
  string color;
  sequence<GenerationTypeFFI> supported_types;
  string? default_model;
};

// ===== TYPO CORRECTION =====

// Result of typo correction operation
[Enum]
interface TypoCorrectionResult {
  Success(string corrected_text, boolean has_changes);
  Error(string message);
};

// ===== CORE INTERFACE (rig-core based) =====
// New simplified interface using rig-core for AI provider integration.
// This provides a cleaner API compared to v1 and will eventually replace it.

[Error]
enum AetherFfiError {
    "Config",
    "Provider",
    "Tool",
    "Memory",
    "Cancelled",
};

callback interface AetherEventHandler {
    void on_thinking();
    void on_tool_start(string tool_name);
    void on_tool_result(string tool_name, string result);
    void on_stream_chunk(string text);
    void on_complete(string response);
    void on_error(string message);
    void on_memory_stored();
    // Agent execution mode notification
    void on_agent_mode_detected(ExecutableTaskFFI task);

    // Hot-reload callbacks for MCP/Skills/Custom tools
    // Called when tool registry is updated (MCP server added/removed, skill installed/deleted)
    void on_tools_changed(u32 tool_count);
    // Called when MCP servers have finished starting (with startup report)
    void on_mcp_startup_complete(McpStartupReportFFI report);

    // Runtime update notification (add-runtime-manager Phase 7)
    // Called when runtime updates are available (checked in background at startup)
    void on_runtime_updates_available(sequence<RuntimeUpdateInfo> updates);

    // Agentic loop callbacks (Phase 5)
    // Called when a new session is created
    void on_session_started(string session_id);
    // Called when tool execution starts (with call_id for tracking)
    void on_tool_call_started(string call_id, string tool_name);
    // Called when tool execution completes
    void on_tool_call_completed(string call_id, string output);
    // Called when tool execution fails
    void on_tool_call_failed(string call_id, string error, boolean is_retryable);
    // Called on each loop iteration with progress update
    void on_loop_progress(string session_id, u32 iteration, string status);
    // Called when a plan is created for multi-step task
    void on_plan_created(string session_id, sequence<string> steps);
    // Called when session completes
    void on_session_completed(string session_id, string summary);
    // Called when sub-agent is started
    void on_subagent_started(string parent_session_id, string child_session_id, string agent_id);
    // Called when sub-agent completes
    void on_subagent_completed(string child_session_id, boolean success, string summary);

    // DAG Plan Confirmation callback
    // Called when a DAG task plan requires user confirmation before execution.
    // Swift should display the plan and call AetherCore.confirm_task_plan() with user's decision.
    void on_plan_confirmation_required(string plan_id, DagTaskPlan plan);

    // User Input Request callback
    // Called when the agent loop needs user input during execution.
    // Swift should display the question (and optional choices) and call
    // AetherCore.respond_to_user_input() with the user's response.
    void on_user_input_request(string request_id, string question, sequence<string> options);

    // Part Update callback (message flow rendering)
    // Called when a session part is added, updated, or removed.
    // Swift should use this to render real-time message flow updates:
    // - Tool calls with status (Pending → Running → Completed/Failed)
    // - Streaming AI responses (text chunks via delta field)
    // - Sub-agent progress (tool uses, tokens)
    void on_part_update(PartUpdateEventFFI event);
};

interface AetherCore {
    // AI PROCESSING
    [Throws=AetherFfiError]
    void process(string input, ProcessOptions? options);

    void cancel();
    boolean is_cancelled();

    sequence<ToolInfoFFI> list_tools();

    [Throws=AetherFfiError]
    sequence<MemoryItem> search_memory(string query, u32 limit);

    [Throws=AetherFfiError]
    void clear_memory();

    [Throws=AetherFfiError]
    void reload_config();

    // CONFIG MANAGEMENT (Config Management)
    [Throws=AetherFfiError]
    FullConfig load_config();

    [Throws=AetherFfiError]
    void update_provider(string name, ProviderConfig provider);

    [Throws=AetherFfiError]
    void delete_provider(string name);

    [Throws=AetherFfiError]
    void update_generation_provider(string name, GenerationProviderConfigFFI provider);

    // Get a single generation provider configuration by name
    GenerationProviderConfigFFI? get_generation_provider_config(string name);

    [Throws=AetherFfiError]
    void delete_generation_provider(string name);

    [Throws=AetherFfiError]
    void update_routing_rules(sequence<RoutingRuleConfig> rules);

    [Throws=AetherFfiError]
    void update_shortcuts(ShortcutsConfig shortcuts);

    [Throws=AetherFfiError]
    void update_behavior(BehaviorConfig behavior);

    [Throws=AetherFfiError]
    void update_trigger_config(TriggerConfig trigger);

    [Throws=AetherFfiError]
    void update_general_config(GeneralConfig config);

    [Throws=AetherFfiError]
    void update_search_config(SearchConfig search);

    [Throws=AetherFfiError]
    void update_typo_correction_config(TypoCorrectionConfig typo_correction);

    [Throws=AetherFfiError]
    void update_policies(PoliciesConfig policies);

    // Test search provider with ad-hoc config (Config Management)
    [Throws=AetherFfiError]
    ProviderTestResult test_search_provider_with_config(SearchProviderTestConfig config);

    [Throws=AetherFfiError]
    boolean validate_regex(string pattern);

    TestConnectionResult test_provider_connection_with_config(string provider_name, ProviderConfig provider_config);

    string? get_default_provider();

    [Throws=AetherFfiError]
    void set_default_provider(string provider_name);

    sequence<string> get_enabled_providers();

    // MCP MANAGEMENT (Config Management)
    McpSettingsConfig get_mcp_config();

    [Throws=AetherFfiError]
    void update_mcp_config(McpSettingsConfig config);

    sequence<McpServerConfig> list_mcp_servers();

    McpServerConfig? get_mcp_server(string id);

    McpServerStatusInfo get_mcp_server_status(string id);

    [Throws=AetherFfiError]
    void add_mcp_server(McpServerConfig config);

    [Throws=AetherFfiError]
    void update_mcp_server(McpServerConfig config);

    [Throws=AetherFfiError]
    void delete_mcp_server(string id);

    sequence<string> get_mcp_server_logs(string id, u32 max_lines);

    string export_mcp_config_json();

    [Throws=AetherFfiError]
    void import_mcp_config_json(string json);

    // MEMORY MANAGEMENT (Config Management)
    MemoryConfig get_memory_config();

    [Throws=AetherFfiError]
    void update_memory_config(MemoryConfig config);

    [Throws=AetherFfiError]
    void delete_memory(string id);

    [Throws=AetherFfiError]
    MemoryStats get_memory_stats();

    [Throws=AetherFfiError]
    sequence<AppMemoryInfo> get_memory_app_list();

    [Throws=AetherFfiError]
    u64 clear_memories(string? app_bundle_id, string? window_title);

    [Throws=AetherFfiError]
    u64 clear_facts();

    [Throws=AetherFfiError]
    u64 delete_memories_by_topic_id(string topic_id);

    [Throws=AetherFfiError]
    CompressionStats get_compression_stats();

    [Throws=AetherFfiError]
    CompressionResult trigger_compression();

    // SKILLS MANAGEMENT (Config Management)
    [Throws=AetherFfiError]
    sequence<SkillInfo> list_skills();

    [Throws=AetherFfiError]
    SkillInfo install_skill(string url);

    [Throws=AetherFfiError]
    sequence<string> install_skills_from_zip(string zip_path);

    [Throws=AetherFfiError]
    void delete_skill(string skill_id);

    [Throws=AetherFfiError]
    string get_skills_dir();

    void refresh_skills();

    // PLUGINS MANAGEMENT (Claude Code Compatible)
    // List all installed plugins
    [Throws=AetherFfiError]
    sequence<PluginInfoFFI> list_plugins();

    // Enable a plugin
    [Throws=AetherFfiError]
    void enable_plugin(string name);

    // Disable a plugin
    [Throws=AetherFfiError]
    void disable_plugin(string name);

    // Load a plugin from a custom path (for development)
    [Throws=AetherFfiError]
    PluginInfoFFI load_plugin_from_path(string path);

    // List all skills from enabled plugins
    [Throws=AetherFfiError]
    sequence<PluginSkillFFI> list_plugin_skills();

    // Execute a plugin skill
    [Throws=AetherFfiError]
    string execute_plugin_skill(string plugin_name, string skill_name, string arguments);

    // Get the plugins directory path
    string get_plugins_dir();

    // Refresh plugins (reload from disk)
    [Throws=AetherFfiError]
    u32 refresh_plugins();

    // Get skill instructions for prompt injection
    [Throws=AetherFfiError]
    string get_plugin_skill_instructions();

    // Install a plugin from a Git repository URL
    [Throws=AetherFfiError]
    PluginInfoFFI install_plugin_from_git(string url);

    // Install plugins from a ZIP file
    [Throws=AetherFfiError]
    sequence<string> install_plugins_from_zip(string zip_path);

    // Uninstall a plugin
    [Throws=AetherFfiError]
    void uninstall_plugin(string name);

    // TOOL REGISTRY (Config Management)
    sequence<UnifiedToolInfo> list_builtin_tools();

    // MULTI-TURN CONVERSATION (Config Management)
    // Generate a title for a conversation topic using AI
    [Throws=AetherFfiError]
    string generate_topic_title(string user_input, string ai_response);

    // Get root commands from the tool registry for command completion
    sequence<CommandNode> get_root_commands_from_registry();

    // LOGGING (Config Management)
    // Get current log level
    LogLevel get_log_level();

    // Set log level
    [Throws=AetherFfiError]
    void set_log_level(LogLevel level);

    // Get log directory path
    [Throws=AetherFfiError]
    string get_log_directory();

    // MEMORY SEARCH WITH FILTER (Config Management)
    // Search memories with optional app/window filter
    [Throws=AetherFfiError]
    sequence<MemoryEntry> search_memories(string? app_bundle_id, string? window_title, u32 limit);

    // VISION/OCR (Config Management)
    // Extract text from image data using OCR
    [Throws=AetherFfiError]
    string extract_text(sequence<u8> image_data);

    // ===== MEDIA GENERATION =====

    // List all registered generation providers
    sequence<GenerationProviderInfoFFI> list_generation_providers();

    // Generate an image from text prompt
    [Throws=AetherFfiError]
    GenerationOutputFFI generate_image(string provider_name, string prompt, GenerationParamsFFI? params);

    // Generate speech from text (TTS)
    [Throws=AetherFfiError]
    GenerationOutputFFI generate_speech(string provider_name, string text, GenerationParamsFFI? params);

    // Generate audio/music from text prompt
    [Throws=AetherFfiError]
    GenerationOutputFFI generate_audio(string provider_name, string prompt, GenerationParamsFFI? params);

    // Generate video from text prompt
    [Throws=AetherFfiError]
    GenerationOutputFFI generate_video(string provider_name, string prompt, GenerationParamsFFI? params);

    // Generic generate method for any type
    [Throws=AetherFfiError]
    GenerationOutputFFI generate(string provider_name, GenerationTypeFFI generation_type, string prompt, GenerationParamsFFI? params);

    // Check progress of a long-running generation
    [Throws=AetherFfiError]
    GenerationProgressFFI check_generation_progress(string provider_name, string job_id);

    // Cancel a running generation
    [Throws=AetherFfiError]
    void cancel_generation(string provider_name, string job_id);

    // Get providers that support a specific generation type
    sequence<GenerationProviderInfoFFI> get_providers_for_type(GenerationTypeFFI generation_type);

    // Edit an existing image using a prompt (image-to-image / inpainting)
    // Requires reference_image in params
    [Throws=AetherFfiError]
    GenerationOutputFFI edit_image(string provider_name, string prompt, GenerationParamsFFI params);

    // Check if a provider supports image editing
    boolean provider_supports_image_editing(string provider_name);

    // Test a generation provider connection (for validating before saving)
    TestConnectionResult test_generation_provider_connection(
        string provider_type,
        string api_key,
        string? base_url,
        string? model
    );

    // ===== COWORK TASK ORCHESTRATION =====

    // Note: agent_get_config and agent_update_config have been removed.
    // Core execution parameters are now hardcoded for security and stability.

    // Plan a task from natural language request
    // Returns a task graph that can be reviewed before execution
    [Throws=AetherFfiError]
    AgentTaskGraphFFI agent_plan(string request);

    // Execute a task graph
    // Returns execution summary when complete
    [Throws=AetherFfiError]
    AgentExecutionSummaryFFI agent_execute(AgentTaskGraphFFI graph);

    // Get current execution state
    AgentExecutionState agent_get_state();

    // Pause execution (running tasks complete, no new tasks start)
    void agent_pause();

    // Resume execution after pause
    void agent_resume();

    // Cancel execution (running tasks complete, then terminates)
    void agent_cancel();

    // Check if execution is paused
    boolean agent_is_paused();

    // Check if execution is cancelled
    boolean agent_is_cancelled();

    // Subscribe to progress events
    void agent_subscribe(AgentProgressHandler handler);

    // ===== CODE EXECUTION CONFIG =====

    // Get code execution configuration
    CodeExecConfigFFI agent_get_code_exec_config();

    // Update code execution configuration
    [Throws=AetherFfiError]
    void agent_update_code_exec_config(CodeExecConfigFFI config);

    // ===== FILE OPERATIONS CONFIG =====

    // Get file operations configuration
    FileOpsConfigFFI agent_get_file_ops_config();

    // Update file operations configuration
    [Throws=AetherFfiError]
    void agent_update_file_ops_config(FileOpsConfigFFI config);

    // ===== MODEL ROUTER =====

    // Get all configured model profiles
    sequence<ModelProfileFFI> agent_get_model_profiles();

    // Get model routing rules
    ModelRoutingRulesFFI agent_get_routing_rules();

    // Update a model profile (add or modify)
    [Throws=AetherFfiError]
    void agent_update_model_profile(ModelProfileFFI profile);

    // Delete a model profile by ID
    [Throws=AetherFfiError]
    void agent_delete_model_profile(string profile_id);

    // Update a task type to model mapping
    [Throws=AetherFfiError]
    void agent_update_routing_rule(string task_type, string model_id);

    // Delete a task type mapping
    [Throws=AetherFfiError]
    void agent_delete_routing_rule(string task_type);

    // Update cost strategy
    [Throws=AetherFfiError]
    void agent_update_cost_strategy(ModelCostStrategyFFI strategy);

    // Update default model
    [Throws=AetherFfiError]
    void agent_update_default_model(string model_id);

    // ===== MODEL HEALTH MONITORING (model-router-intelligence) =====

    // Get health summary for all tracked models
    sequence<ModelHealthSummaryFFI> agent_get_model_health_summaries();

    // Get health summary for a specific model
    ModelHealthSummaryFFI? agent_get_model_health(string model_id);

    // Get overall health statistics
    HealthStatisticsFFI agent_get_health_statistics();

    // ===== BUDGET MANAGEMENT (model-router-p1-improvements) =====

    // Get budget status overview
    BudgetStatusFFI agent_get_budget_status();

    // Get budget status for a specific scope
    BudgetStatusFFI agent_get_budget_status_for_scope(string scope_type, string? scope_id);

    // Get a single budget limit status by ID
    BudgetLimitStatusFFI? agent_get_budget_limit(string limit_id);

    // ===== SESSION MANAGEMENT (Phase 5) =====

    // Resume a previously saved session
    [Throws=AetherFfiError]
    void resume_session(string session_id);

    // Get current active session ID
    string? get_current_session_id();

    // List recent sessions
    sequence<SessionSummary> list_recent_sessions(u32 limit);

    // Cancel the current session
    [Throws=AetherFfiError]
    boolean cancel_session();

    // ===== DAG PLAN CONFIRMATION (plan-confirmation-flow) =====

    // Confirm or cancel a pending DAG task plan
    // Called by Swift after displaying confirmation dialog
    // Returns true if confirmation was found and completed, false if expired or not found
    boolean confirm_task_plan(string plan_id, boolean confirmed);

    // ===== USER INPUT REQUEST (agent-loop-interactive-input) =====

    // Respond to a user input request from the agent loop
    // Called by Swift after collecting user input
    // Returns true if request was found and completed, false if not found
    boolean respond_to_user_input(string request_id, string response);

    // ===== RUNTIME MANAGEMENT (add-runtime-manager) =====

    // List all registered runtimes with their status
    sequence<RuntimeInfo> list_runtimes();

    // Check if a specific runtime is installed
    boolean is_runtime_installed(string runtime_id);

    // Install a runtime (lazy installation)
    // Returns immediately if already installed
    [Throws=AetherFfiError]
    void install_runtime(string runtime_id);

    // Check for available updates across all runtimes
    // Returns list of runtimes with available updates
    [Throws=AetherFfiError]
    sequence<RuntimeUpdateInfo> check_runtime_updates();

    // Update a specific runtime to latest version
    [Throws=AetherFfiError]
    void update_runtime(string runtime_id);

    // Get Node.js runtime path (via fnm)
    // Returns None if fnm/Node.js is not installed
    string? get_node_path();

    // Get npm runtime path (via fnm)
    // Returns None if fnm/Node.js is not installed
    string? get_npm_path();

    // Get Python runtime path (via uv)
    // Returns None if uv/Python is not installed
    string? get_python_path();

    // Get yt-dlp runtime path
    // Returns None if yt-dlp is not installed
    string? get_ytdlp_path();

    // ===== TYPO CORRECTION =====

    // Correct typos in text using AI
    // Bypasses complex routing for minimal latency (sync method, uses internal runtime)
    TypoCorrectionResult correct_typo(string text);
};

// Session summary for FFI (Phase 5)
dictionary SessionSummary {
    string id;
    string agent_id;
    string status;
    u32 iteration_count;
    i64 created_at;
    i64 updated_at;
};

dictionary ProcessOptions {
    string? app_context;
    string? window_title;
    string? topic_id;    // Topic ID for multi-turn conversations (nil = "single-turn")
    boolean stream;
    sequence<MediaAttachment>? attachments;
    string? preferred_language;  // Preferred language for AI responses (e.g., "zh-Hans", "en")
};

dictionary ToolInfoFFI {
    string name;
    string description;
    string source;
};

// ===== PLUGIN SYSTEM TYPES (Claude Code Compatible) =====

// Plugin information for FFI/UI display
dictionary PluginInfoFFI {
    string name;              // Plugin name
    string version;           // Plugin version
    string description;       // Plugin description
    boolean enabled;          // Whether plugin is enabled
    string path;              // Plugin root path
    u32 skills_count;         // Number of skills
    u32 agents_count;         // Number of agents
    u32 hooks_count;          // Number of hook events
    u32 mcp_servers_count;    // Number of MCP servers
};

// Plugin skill information for FFI/UI display
dictionary PluginSkillFFI {
    string qualified_name;    // Fully qualified skill name (plugin:skill)
    string plugin_name;       // Plugin name
    string skill_name;        // Skill name
    string description;       // Skill description
    boolean is_command;       // Whether this is a command (user-triggered) or skill (auto-invocable)
};

// ===== END PLUGIN SYSTEM TYPES =====

dictionary MemoryItem {
    string id;
    string user_input;
    string assistant_response;
    i64 timestamp;
    string? app_context;
};

// ===== PART UPDATE EVENTS (message flow rendering) =====

// Part event type for UI updates
enum PartEventTypeFFI {
  "Added",    // Part was added to the session
  "Updated",  // Part was updated (e.g., tool call status changed, streaming text)
  "Removed",  // Part was removed (e.g., compaction)
};

// Part update event for UI rendering
// Contains all information needed to render a message flow update
dictionary PartUpdateEventFFI {
  string session_id;    // Session ID this part belongs to
  string part_id;       // Unique part identifier
  string part_type;     // Part type name (e.g., "tool_call", "ai_response")
  PartEventTypeFFI event_type;  // Event type (Added, Updated, Removed)
  string part_json;     // Serialized part data as JSON
  string? delta;        // Delta content for streaming updates (text chunks)
  i64 timestamp;        // Timestamp when the event occurred
};

// ===== AGENT EXECUTION MODE (agent-execution-mode) =====

// Task category for executable tasks
enum TaskCategoryFFI {
  "General",            // General task (explicit /agent command)
  "FileOrganize",       // File organization (sort, classify)
  "FileOperation",      // File operations (read, write, search)
  "FileTransfer",       // File transfer (move, copy)
  "FileCleanup",        // File cleanup (delete, archive)
  "CodeExecution",      // Code execution
  "AppLaunch",          // Application launch
  "AppAutomation",      // Application automation
  "DocumentGeneration", // Document generation (new name)
  "DocumentGenerate",   // Document generation (legacy alias)
  "ImageGeneration",    // Image generation
  "VideoGeneration",    // Video generation
  "AudioGeneration",    // Audio generation
  "SpeechGeneration",   // Speech generation (TTS)
  "WebSearch",          // Web search
  "WebFetch",           // Web fetch (page content)
  "SystemInfo",         // System information queries
  "MediaDownload",      // Media download (YouTube, etc.)
  "TextProcessing",     // Text processing
  "DataProcess",        // Data processing
};

// Execution intent classification result
enum ExecutionIntentTypeFFI {
  "Executable",      // Directly executable task
  "Ambiguous",       // Needs clarification
  "Conversational",  // Pure conversation
};

// Parameter source for transparency
enum ParameterSourceFFI {
  "UserPreference",  // From user's stored preferences
  "Preset",          // From preset scenario
  "Inference",       // Inferred from context
  "Default",         // Default fallback
};

// How to organize files
enum OrganizeMethodFFI {
  "ByExtension",  // Group by file extension
  "ByCategory",   // Group by category
  "ByDate",       // Group by date
};

// How to handle file conflicts
enum ConflictResolutionFFI {
  "Skip",       // Skip conflicting files
  "Rename",     // Rename with suffix
  "Overwrite",  // Overwrite existing files
};

// Executable task information
dictionary ExecutableTaskFFI {
  TaskCategoryFFI category;     // Task category
  string action;                 // Action description
  string? target;               // Target path or object
  f32 confidence;               // Classification confidence (0.0-1.0)
};

// Ambiguous task information
dictionary AmbiguousTaskFFI {
  string task_hint;       // Hint about the task
  string clarification;   // Clarification question
};

// Task parameters for execution
dictionary TaskParametersFFI {
  OrganizeMethodFFI organize_method;
  ConflictResolutionFFI conflict_resolution;
  ParameterSourceFFI source;
};

// ===== END AGENT EXECUTION MODE =====

// ===== RUNTIME MANAGER TYPES (add-runtime-manager) =====

// Runtime information for UI display
dictionary RuntimeInfo {
  string id;              // Runtime ID (e.g., "fnm", "uv", "yt-dlp")
  string name;            // Human-readable name (e.g., "fnm (Node.js)")
  string description;     // Description of the runtime
  string? version;        // Installed version (None if not installed)
  boolean installed;      // Whether the runtime is installed
};

// Update information for available updates
dictionary RuntimeUpdateInfo {
  string runtime_id;        // Runtime ID
  string current_version;   // Currently installed version
  string latest_version;    // Latest available version
};

// ===== MODEL ROUTER TYPES (add-agent-model-router) =====

// Model capability tags for characterizing model strengths
enum ModelCapabilityFFI {
  "CodeGeneration",      // Code creation and completion
  "CodeReview",          // Code analysis and review
  "TextAnalysis",        // Text understanding and summarization
  "ImageUnderstanding",  // Vision/image analysis
  "VideoUnderstanding",  // Video analysis
  "LongContext",         // Large context window support (>100k tokens)
  "Reasoning",           // Complex reasoning tasks
  "LocalPrivacy",        // Local execution for privacy-sensitive data
  "FastResponse",        // Low latency response (<2s)
  "SimpleTask",          // Simple task handling (Q&A, classification)
  "LongDocument",        // Long document processing
};

// Cost tier for cost-aware routing decisions
enum ModelCostTierFFI {
  "Free",    // Free tier (local models)
  "Low",     // Low cost tier (~$0.25/1M tokens)
  "Medium",  // Medium cost tier (~$3/1M tokens)
  "High",    // High cost tier (~$15/1M tokens)
};

// Latency tier for latency-sensitive task routing
enum ModelLatencyTierFFI {
  "Fast",    // Fast response (<2s typical)
  "Medium",  // Medium latency (2-10s typical)
  "Slow",    // Slow response (>10s typical)
};

// Cost optimization strategy for model selection
enum ModelCostStrategyFFI {
  "Cheapest",     // Always choose the cheapest model that can handle the task
  "Balanced",     // Balance cost and quality (default)
  "BestQuality",  // Always choose the best quality model regardless of cost
};

// Model profile describing an AI model's characteristics
dictionary ModelProfileFFI {
  string id;                                  // Unique identifier (e.g., "claude-opus", "gpt-4o")
  string provider;                            // Provider name (anthropic, openai, google, ollama)
  string model;                               // Model name for API calls
  sequence<ModelCapabilityFFI> capabilities;  // Capability tags
  ModelCostTierFFI cost_tier;                 // Cost tier for cost-aware routing
  ModelLatencyTierFFI latency_tier;           // Latency tier for latency-sensitive tasks
  u32? max_context;                           // Maximum context window in tokens
  boolean local;                              // Whether this is a local model (no network calls)
};

// Task type to model mapping entry
dictionary TaskTypeMappingFFI {
  string task_type;  // Task type string (e.g., "code_generation")
  string model_id;   // Model profile ID (e.g., "claude-opus")
};

// Capability to model mapping entry
dictionary CapabilityMappingFFI {
  ModelCapabilityFFI capability;  // Capability enum value
  string model_id;                // Model profile ID
};

// Model routing rules configuration
dictionary ModelRoutingRulesFFI {
  sequence<TaskTypeMappingFFI> task_type_mappings;    // Task type to model mappings
  sequence<CapabilityMappingFFI> capability_mappings; // Capability to model mappings
  ModelCostStrategyFFI cost_strategy;                 // Cost optimization strategy
  string? default_model;                              // Default model profile ID
  boolean enable_pipelines;                           // Enable multi-model pipeline execution
};

// Result of executing a single pipeline stage
dictionary StageResultFFI {
  string stage_id;       // ID of the stage
  string model_used;     // Model profile ID used
  string provider;       // Provider name
  string output_json;    // Output as JSON string
  u32 tokens_used;       // Number of tokens used
  u64 duration_ms;       // Execution duration in milliseconds
  boolean success;       // Whether the stage completed successfully
  string? error;         // Error message if failed
};

// ===== MODEL HEALTH MONITORING (model-router-intelligence) =====

// Health status of an AI model
enum ModelHealthStatusFFI {
  "Healthy",       // Normal service - model is fully available
  "Degraded",      // Available but impaired (high latency, near rate limit)
  "Unhealthy",     // Temporarily unavailable due to failures
  "CircuitOpen",   // Circuit breaker triggered - blocking all requests
  "HalfOpen",      // Half-open state - allowing limited test requests
  "Unknown",       // Insufficient data to determine health
};

// Summarized health information for a single model (UI display)
dictionary ModelHealthSummaryFFI {
  string model_id;             // Model identifier
  ModelHealthStatusFFI status; // Current health status
  string status_text;          // Human-readable status text (e.g., "Healthy")
  string status_emoji;         // Status emoji for display
  string? reason;              // Reason for current status (if degraded/unhealthy)
  u32 consecutive_successes;   // Count of consecutive successful calls
  u32 consecutive_failures;    // Count of consecutive failed calls
};

// Overall health statistics for all tracked models
dictionary HealthStatisticsFFI {
  u32 total;         // Total number of tracked models
  u32 healthy;       // Number of healthy models
  u32 degraded;      // Number of degraded models
  u32 unhealthy;     // Number of unhealthy models
  u32 circuit_open;  // Number of models with open circuits
  u32 half_open;     // Number of models in half-open state
  u32 unknown;       // Number of models with unknown status
  f64 healthy_percent;  // Percentage of healthy models (0.0-100.0)
};

// ===== END MODEL HEALTH MONITORING =====

// ===== BUDGET MANAGEMENT (model-router-p1-improvements) =====

// Budget scope type
[Enum]
interface BudgetScopeFFI {
  Global();
  Project(string id);
  Session(string id);
  Model(string id);
};

// Budget period type
enum BudgetPeriodFFI {
  "Lifetime",  // Never resets
  "Daily",     // Resets daily
  "Weekly",    // Resets weekly
  "Monthly",   // Resets monthly
};

// Budget enforcement action
enum BudgetEnforcementFFI {
  "WarnOnly",   // Log warning but allow
  "SoftBlock",  // Block new requests
  "HardBlock",  // Block immediately
};

// Status of a single budget limit
dictionary BudgetLimitStatusFFI {
  string limit_id;              // Limit unique identifier
  BudgetScopeFFI scope;         // Scope this limit applies to
  string scope_display;         // Scope as display string
  BudgetPeriodFFI period;       // Budget period type
  string period_display;        // Period as display string
  f64 limit_usd;                // Configured limit in USD
  f64 spent_usd;                // Current spend in USD
  f64 remaining_usd;            // Remaining budget in USD
  f64 used_percent;             // Percentage used (0.0 - 1.0)
  BudgetEnforcementFFI enforcement;  // Enforcement action
  boolean is_exceeded;          // Whether the limit is exceeded
  boolean is_warning;           // Whether any warning threshold crossed
  i64 next_reset_timestamp;     // Next reset timestamp (Unix seconds)
  string next_reset_display;    // Human-readable time until reset
};

// Overall budget status summary
dictionary BudgetStatusFFI {
  boolean enabled;              // Whether budget management is enabled
  u32 total_limits;             // Total configured limits
  u32 exceeded_count;           // Limits currently exceeded
  u32 warning_count;            // Limits with active warnings
  f64 total_spent_usd;          // Total spent across all scopes
  f64 min_remaining_usd;        // Minimum remaining across limits
  sequence<BudgetLimitStatusFFI> limits;  // Per-limit status
  string status_emoji;          // Status emoji for display
  string status_message;        // Human-readable status
};

// ===== END BUDGET MANAGEMENT =====

// ===== COWORK TASK ORCHESTRATION (add-agent-task-orchestration) =====

// Agent execution state
enum AgentExecutionState {
  "Idle",                 // Not executing
  "Planning",             // Planning a task
  "AwaitingConfirmation", // Waiting for user confirmation
  "Executing",            // Executing tasks
  "Paused",               // Execution paused
  "Cancelled",            // Execution cancelled
  "Completed",            // Execution completed
};

// Agent task status state (simplified for FFI)
enum AgentTaskStatusState {
  "Pending",    // Task waiting to execute
  "Running",    // Task currently executing
  "Completed",  // Task completed successfully
  "Failed",     // Task failed
  "Cancelled",  // Task was cancelled
};

// Agent task type category
enum AgentTaskTypeCategory {
  "FileOperation",        // File system operations
  "CodeExecution",        // Code/script execution
  "DocumentGeneration",   // Document generation (Excel, PDF, etc.)
  "AppAutomation",        // macOS app automation
  "AiInference",          // AI inference task
  "ImageGeneration",      // Image generation (DALL-E, Stable Diffusion, etc.)
  "VideoGeneration",      // Video generation (Runway, Pika, etc.)
  "AudioGeneration",      // Audio generation (TTS, music, sound effects)
};

// Note: AgentConfigFFI has been removed.
// Core execution parameters (require_confirmation, max_parallelism, max_task_retries)
// are now hardcoded for security and stability.

// Code execution configuration (Phase 3)
dictionary CodeExecConfigFFI {
  boolean enabled;                    // Enable code execution (disabled by default)
  string default_runtime;             // Default runtime (shell, python, node)
  u64 timeout_seconds;                // Execution timeout in seconds
  boolean sandbox_enabled;            // Enable sandboxed execution
  boolean allow_network;              // Allow network access in sandbox
  sequence<string> allowed_runtimes;  // Allowed runtimes (empty = all)
  string? working_directory;          // Working directory for executions
  sequence<string> pass_env;          // Environment variables to pass
  sequence<string> blocked_commands;  // Blocked command patterns
};

// File operations configuration (Phase 2)
dictionary FileOpsConfigFFI {
  boolean enabled;                           // Enable file operations
  sequence<string> allowed_paths;            // Allowed paths (glob patterns)
  sequence<string> denied_paths;             // Denied paths (glob patterns)
  u64 max_file_size;                         // Max file size in bytes
  boolean require_confirmation_for_write;    // Require confirmation for write
  boolean require_confirmation_for_delete;   // Require confirmation for delete
};

// Agent task (simplified for FFI)
dictionary AgentTaskFFI {
  string id;                         // Unique task identifier
  string name;                       // Human-readable name
  string? description;               // Optional description
  AgentTaskTypeCategory task_type;  // Task type category
  AgentTaskStatusState status;      // Current status
  f32 progress;                      // Progress (0.0 - 1.0)
  string? error_message;             // Error message if failed
};

// Agent task dependency
dictionary AgentTaskDependencyFFI {
  string from_task_id;  // Predecessor task ID
  string to_task_id;    // Successor task ID
};

// Agent task graph (simplified for FFI)
dictionary AgentTaskGraphFFI {
  string id;                                   // Graph unique identifier
  string title;                                // Graph title
  string? original_request;                    // Original user request
  sequence<AgentTaskFFI> tasks;               // All tasks in the graph
  sequence<AgentTaskDependencyFFI> edges;     // Task dependencies
};

// Agent execution summary
dictionary AgentExecutionSummaryFFI {
  string graph_id;           // Graph ID that was executed
  u32 total_tasks;           // Total number of tasks
  u32 completed_tasks;       // Successfully completed tasks
  u32 failed_tasks;          // Failed tasks
  u32 cancelled_tasks;       // Cancelled tasks
  u64 total_duration_ms;     // Total execution duration in milliseconds
  sequence<string> errors;   // Error messages from failed tasks
};

// Agent progress event type
enum AgentProgressEventType {
  "TaskStarted",      // Task execution started
  "TaskProgress",     // Task progress update
  "TaskCompleted",    // Task completed successfully
  "TaskFailed",       // Task failed
  "TaskCancelled",    // Task was cancelled
  "GraphProgress",    // Overall graph progress update
  "GraphCompleted",   // Entire graph completed
};

// Agent progress event (for real-time updates)
dictionary AgentProgressEventFFI {
  AgentProgressEventType event_type;  // Event type
  string? task_id;                     // Task ID (if task-related)
  string? task_name;                   // Task name (if task-related)
  f32 progress;                        // Progress value (0.0 - 1.0)
  string? message;                     // Optional message
  string? error;                       // Error message (for failed events)
};

// Callback interface for Agent progress events
callback interface AgentProgressHandler {
  // Called when a progress event occurs
  void on_progress_event(AgentProgressEventFFI event);
};
