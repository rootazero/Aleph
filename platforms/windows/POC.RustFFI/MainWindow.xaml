<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="POC.RustFFI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="POC-3: Rust FFI Callback Test">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock
            Grid.Row="0"
            Text="POC-3: Rust FFI Callback Validation"
            Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Instructions -->
        <TextBlock
            Grid.Row="1"
            TextWrapping="Wrap"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}">
            <Run Text="This POC validates:"/>
            <LineBreak/>
            <Run Text="1. Loading aethecore.dll and calling Rust functions"/>
            <LineBreak/>
            <Run Text="2. Registering C# callbacks that Rust can invoke"/>
            <LineBreak/>
            <Run Text="3. Thread marshaling from Rust thread to UI thread"/>
            <LineBreak/>
            <LineBreak/>
            <Run Text="Prerequisites: Build aethecore.dll with 'cargo build --release --features cabi'"/>
        </TextBlock>

        <!-- Status -->
        <Border
            Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Padding="16">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="DLL Status:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DllStatus" Text="Not loaded"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Core Version:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CoreVersion" Text="-"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Callbacks:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CallbackStatus" Text="Not registered"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <Button
                x:Name="InitButton"
                Content="Initialize Core"
                Click="InitButton_Click"
                Style="{StaticResource AccentButtonStyle}"/>

            <Button
                x:Name="TestCallbackButton"
                Content="Test Callbacks (Simulated)"
                Click="TestCallbackButton_Click"
                IsEnabled="False"/>

            <Button
                x:Name="CleanupButton"
                Content="Cleanup"
                Click="CleanupButton_Click"
                IsEnabled="False"/>

            <Button Content="Clear Log" Click="ClearLog_Click"/>
        </StackPanel>

        <!-- Log -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Log:" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <TextBlock
                    x:Name="LogText"
                    FontFamily="Consolas"
                    FontSize="12"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
