<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aether.Views.Settings.McpSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" MaxWidth="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar - Server List -->
        <Border Grid.Column="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Server List -->
                <ListView x:Name="ServerListView"
                          Grid.Row="0"
                          SelectionMode="Single"
                          SelectionChanged="ServerListView_SelectionChanged"
                          Padding="8">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE912;"
                                          FontSize="14"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>

                                <Ellipse Grid.Column="2"
                                         Width="8" Height="8"
                                         Fill="{Binding StatusColor}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyState"
                            Grid.Row="0"
                            Visibility="Visible"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="8">
                    <FontIcon Glyph="&#xE912;" FontSize="32"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="No MCP servers"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextAlignment="Center"/>
                    <TextBlock Text="Add a server to get started"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- Bottom Toolbar -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Click="AddServer_Click"
                                ToolTipService.ToolTip="Add MCP Server">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                <TextBlock Text="Add"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                x:Name="DeleteButton"
                                Click="DeleteServer_Click"
                                IsEnabled="False"
                                ToolTipService.ToolTip="Delete Server">
                            <FontIcon Glyph="&#xE74D;" FontSize="12"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Right Detail Panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="DetailPanel"
                        Padding="24"
                        Spacing="24"
                        Visibility="Collapsed">

                <!-- Server Header -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  x:Name="ServerIcon"
                                  Glyph="&#xE912;"
                                  FontSize="32"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock x:Name="ServerNameText"
                                       Text="Server Name"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Name="ServerTriggerText"
                                       Text="/mcp/server"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                x:Name="StatusBadge"
                                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                CornerRadius="10"
                                Padding="8,4"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Ellipse Width="6" Height="6"
                                         x:Name="StatusDot"
                                         Fill="{ThemeResource SystemFillColorSuccessBrush}"/>
                                <TextBlock x:Name="StatusText"
                                           Text="Running"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <ToggleSwitch Grid.Column="3"
                                      x:Name="EnabledToggle"
                                      OnContent="Enabled"
                                      OffContent="Disabled"
                                      Toggled="EnabledToggle_Toggled"/>
                    </Grid>
                </Border>

                <!-- Command Section -->
                <Border x:Name="CommandSection"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE756;" FontSize="16"/>
                            <TextBlock Text="Command" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>

                        <!-- Command Path -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Command"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     x:Name="CommandBox"
                                     PlaceholderText="npx"
                                     TextChanged="CommandBox_TextChanged"/>
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Margin="8,0,0,0"
                                    Click="BrowseCommand_Click"/>
                        </Grid>

                        <!-- Arguments -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Arguments"
                                       VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <ItemsControl x:Name="ArgsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Value, Mode=TwoWay}"
                                                         FontFamily="Consolas"/>
                                                <Button Grid.Column="1"
                                                        Margin="4,0,0,0"
                                                        Click="RemoveArg_Click"
                                                        Tag="{Binding}">
                                                    <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Click="AddArg_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE710;" FontSize="10"/>
                                        <TextBlock Text="Add Argument"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Working Directory -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Working Dir"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     x:Name="WorkingDirBox"
                                     PlaceholderText="~/"
                                     TextChanged="WorkingDirBox_TextChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Environment Variables Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8AC;" FontSize="16"/>
                            <TextBlock Text="Environment Variables" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>

                        <TextBlock Text="Define environment variables for this server."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12"/>

                        <ItemsControl x:Name="EnvVarsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Key, Mode=TwoWay}"
                                                 PlaceholderText="KEY"/>
                                        <PasswordBox Grid.Column="1"
                                                     Password="{Binding Value, Mode=TwoWay}"
                                                     PlaceholderText="Value"
                                                     Margin="4,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Margin="4,0,0,0"
                                                Click="ToggleEnvVisibility_Click"
                                                Tag="{Binding}">
                                            <FontIcon Glyph="&#xE7B3;" FontSize="12"/>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Margin="4,0,0,0"
                                                Click="RemoveEnvVar_Click"
                                                Tag="{Binding}">
                                            <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Click="AddEnvVar_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE710;" FontSize="10"/>
                                <TextBlock Text="Add Variable"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Permissions Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72E;" FontSize="16"/>
                            <TextBlock Text="Permissions" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>

                        <ToggleSwitch x:Name="RequiresConfirmationToggle"
                                      Header="Require confirmation"
                                      OnContent="Yes"
                                      OffContent="No"
                                      IsOn="True"
                                      Toggled="RequiresConfirmationToggle_Toggled"/>
                        <TextBlock Text="When enabled, you'll be asked to confirm before this server executes actions."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Action Bar -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Click="ViewLogs_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8A1;" FontSize="12"/>
                                <TextBlock Text="View Logs"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                x:Name="SaveButton"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="False"
                                Click="SaveServer_Click">
                            <TextBlock Text="Save"/>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Empty Detail State -->
            <StackPanel x:Name="EmptyDetailState"
                        Visibility="Visible"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE700;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="Select a server to configure"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Add Server Dialog -->
        <ContentDialog x:Name="AddServerDialog"
                       Title="Add MCP Server"
                       PrimaryButtonText="Add"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="AddServerDialog_PrimaryButtonClick">
            <StackPanel Spacing="16" MinWidth="400">
                <TextBox x:Name="NewServerNameBox"
                         Header="Server Name"
                         PlaceholderText="my-server"/>
                <TextBox x:Name="NewServerCommandBox"
                         Header="Command"
                         PlaceholderText="npx"/>
                <TextBox x:Name="NewServerArgsBox"
                         Header="Arguments (comma-separated)"
                         PlaceholderText="-y, @modelcontextprotocol/server-memory"/>
            </StackPanel>
        </ContentDialog>

        <!-- Status InfoBar -->
        <InfoBar x:Name="StatusInfoBar"
                 Grid.ColumnSpan="2"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"
                 VerticalAlignment="Top"
                 Margin="24"/>
    </Grid>
</UserControl>
