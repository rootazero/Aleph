<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aether.Views.Settings.RuntimesSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <!-- Runtimes Overview -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE756;" FontSize="16"/>
                        <TextBlock Text="Runtime Environments" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Aether manages runtime environments for code execution and media processing. Runtimes are automatically installed and updated as needed."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <!-- Auto-Update Toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Auto-Update Runtimes"/>
                            <TextBlock Text="Automatically update runtimes when new versions are available"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      x:Name="AutoUpdateToggle"
                                      OnContent="On"
                                      OffContent="Off"
                                      IsOn="True"
                                      Toggled="AutoUpdateToggle_Toggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Python Runtime (uv) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                Background="#3776AB"
                                CornerRadius="8">
                            <TextBlock Text="Py"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Python (uv)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Fast Python package installer and environment manager"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="11"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                x:Name="PythonStatusBadge"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="PythonStatusText" Text="Installed" FontSize="11" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PythonVersionText" Text="3.12.0" FontSize="12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="uv Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UvVersionText" Text="0.4.0" FontSize="12" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Location" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PythonLocationText" Text="~/.uv" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:Name="PythonUpdateButton" Click="PythonUpdate_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE777;" FontSize="12"/>
                                <TextBlock Text="Check Update"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="PythonInstallButton" Click="PythonInstall_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                <TextBlock Text="Install"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Node.js Runtime (fnm) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                Background="#339933"
                                CornerRadius="8">
                            <TextBlock Text="N"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Node.js (fnm)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Fast Node.js version manager"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="11"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                x:Name="NodeStatusBadge"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="NodeStatusText" Text="Installed" FontSize="11" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NodeVersionText" Text="20.10.0" FontSize="12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="fnm Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FnmVersionText" Text="1.35.0" FontSize="12" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Location" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="NodeLocationText" Text="~/.fnm" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:Name="NodeUpdateButton" Click="NodeUpdate_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE777;" FontSize="12"/>
                                <TextBlock Text="Check Update"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NodeInstallButton" Click="NodeInstall_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                <TextBlock Text="Install"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- yt-dlp Runtime -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                Background="#FF0000"
                                CornerRadius="8">
                            <FontIcon Glyph="&#xE714;"
                                      FontSize="18"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="yt-dlp" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Video downloader for YouTube and other sites"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="11"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                x:Name="YtdlpStatusBadge"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="YtdlpStatusText" Text="Installed" FontSize="11" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="YtdlpVersionText" Text="2024.01.01" FontSize="12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="YtdlpLocationText" Text="~/.aether/bin/yt-dlp" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:Name="YtdlpUpdateButton" Click="YtdlpUpdate_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE777;" FontSize="12"/>
                                <TextBlock Text="Check Update"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="YtdlpInstallButton" Click="YtdlpInstall_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                <TextBlock Text="Install"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- FFmpeg Runtime -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                Background="#007808"
                                CornerRadius="8">
                            <TextBlock Text="FF"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="FFmpeg" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Media processing toolkit"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="11"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                x:Name="FfmpegStatusBadge"
                                Background="{ThemeResource SystemFillColorCautionBrush}"
                                CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="FfmpegStatusText" Text="Optional" FontSize="11" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FfmpegVersionText" Text="Not installed" FontSize="12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Purpose" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Required for audio extraction and video processing" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button x:Name="FfmpegInstallButton" Click="FfmpegInstall_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                <TextBlock Text="Install"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Update All Button -->
            <Button x:Name="UpdateAllButton"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    Click="UpdateAll_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE777;" FontSize="14"/>
                    <TextBlock Text="Update All Runtimes"/>
                </StackPanel>
            </Button>

            <!-- Status InfoBar -->
            <InfoBar x:Name="StatusInfoBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Informational"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
