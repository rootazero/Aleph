<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aether.Views.Settings.ShortcutsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="24">

            <!-- Halo Activation Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Halo Activation" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Primary Hotkey" FontWeight="SemiBold"/>
                            <TextBlock
                                Text="Double-tap Shift to activate Halo at cursor position"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="12"/>
                        </StackPanel>

                        <Border
                            x:Name="HaloHotkeyDisplay"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="12,8"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                            <TextBlock
                                x:Name="HaloHotkeyText"
                                Text="Shift + Shift"
                                FontFamily="Consolas"
                                FontSize="14"/>
                        </Border>

                        <TextBlock
                            Text="This hotkey cannot be changed in the current version."
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            FontSize="11"
                            FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Conversation Window Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Conversation Window" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Open Conversation" FontWeight="SemiBold"/>
                            <TextBlock
                                Text="Open multi-turn conversation window"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="12"/>
                        </StackPanel>

                        <Border
                            x:Name="ConversationHotkeyDisplay"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="12,8"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Left">
                            <TextBlock
                                x:Name="ConversationHotkeyText"
                                Text="Win + Alt + /"
                                FontFamily="Consolas"
                                FontSize="14"/>
                        </Border>

                        <TextBlock
                            Text="This hotkey cannot be changed in the current version."
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            FontSize="11"
                            FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Quick Actions Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Quick Actions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="16">
                        <!-- Escape to dismiss -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Dismiss Halo" FontWeight="SemiBold"/>
                                <TextBlock
                                    Text="Close the Halo window"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="Esc" FontFamily="Consolas" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Enter to confirm -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Confirm/Send" FontWeight="SemiBold"/>
                                <TextBlock
                                    Text="Send message or confirm action"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="Enter" FontFamily="Consolas" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Ctrl+C to copy -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Copy Response" FontWeight="SemiBold"/>
                                <TextBlock
                                    Text="Copy AI response to clipboard"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="Ctrl + C" FontFamily="Consolas" FontSize="14"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
