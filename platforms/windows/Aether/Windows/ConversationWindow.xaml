<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Aether.Windows.ConversationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aether.ViewModels"
    Title="Aether Conversation">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock
                        x:Name="TitleText"
                        Text="New Conversation"
                        Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock
                        x:Name="StatusText"
                        Text="Ready"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button
                        x:Name="ClearButton"
                        ToolTipService.ToolTip="Clear conversation"
                        Click="ClearButton_Click">
                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                    </Button>
                    <Button
                        x:Name="SettingsButton"
                        ToolTipService.ToolTip="Settings"
                        Click="SettingsButton_Click">
                        <FontIcon Glyph="&#xE713;" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages List -->
        <ScrollViewer
            x:Name="MessagesScrollViewer"
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            Padding="16">
            <ItemsControl
                x:Name="MessagesContainer"
                ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversationMessage">
                        <Border
                            Margin="0,8"
                            Padding="12"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Message Header -->
                                <StackPanel
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,0,0,8">
                                    <Border
                                        Width="24"
                                        Height="24"
                                        CornerRadius="12"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                        <TextBlock
                                            Text="{x:Bind RoleDisplay[0]}"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock
                                        Text="{x:Bind RoleDisplay}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"/>
                                    <TextBlock
                                        Text="{x:Bind TimestampDisplay}"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Message Content -->
                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind Content, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Streaming Indicator -->
        <Border
            x:Name="StreamingIndicator"
            Grid.Row="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            Padding="16,8"
            Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ProgressRing
                    IsActive="True"
                    Width="20"
                    Height="20"/>
                <TextBlock
                    Text="Aether is typing..."
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center"/>
                <Button
                    x:Name="StopButton"
                    Content="Stop"
                    Click="StopButton_Click"
                    VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border
            Grid.Row="3"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="InputTextBox"
                    Grid.Column="0"
                    PlaceholderText="Type a message... (Press Enter to send)"
                    AcceptsReturn="False"
                    TextWrapping="Wrap"
                    MaxHeight="120"
                    KeyDown="InputTextBox_KeyDown"
                    Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button
                    x:Name="SendButton"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="SendButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanSend, Mode=OneWay}"
                    VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE724;" FontSize="16"/>
                        <TextBlock Text="Send"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
