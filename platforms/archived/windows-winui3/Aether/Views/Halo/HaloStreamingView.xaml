<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aleph.Views.Halo.HaloStreamingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer
            x:Name="StreamingScrollViewer"
            VerticalScrollBarVisibility="Auto"
            MaxHeight="250"
            MaxWidth="320">

            <RichTextBlock
                x:Name="StreamingContent"
                FontSize="13"
                Foreground="#E0FFFFFF"
                TextWrapping="Wrap"
                IsTextSelectionEnabled="True"
                Padding="4">

                <Paragraph>
                    <Run x:Name="StreamingRun" Text=""/>
                    <Run x:Name="CursorRun" Text="▌" Foreground="#80FFFFFF"/>
                </Paragraph>
            </RichTextBlock>
        </ScrollViewer>
    </Grid>
</UserControl>
