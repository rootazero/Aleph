<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aleph.Views.Halo.HaloToolView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tool Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <!-- Tool Icon -->
            <Border
                x:Name="IconBorder"
                Width="24"
                Height="24"
                CornerRadius="4"
                Background="#30FFFFFF">
                <FontIcon
                    x:Name="ToolIcon"
                    Glyph="&#xE90F;"
                    FontSize="14"
                    Foreground="#E0FFFFFF"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Border>

            <!-- Tool Name -->
            <TextBlock
                x:Name="ToolNameText"
                Text="Tool"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="#E0FFFFFF"
                VerticalAlignment="Center"/>

            <!-- Status Indicator -->
            <Border
                x:Name="StatusBadge"
                Padding="6,2"
                CornerRadius="8"
                Background="#30FFFFFF"
                VerticalAlignment="Center">
                <TextBlock
                    x:Name="StatusText"
                    Text="Executing"
                    FontSize="11"
                    Foreground="#B0FFFFFF"/>
            </Border>
        </StackPanel>

        <!-- Progress Bar -->
        <ProgressBar
            x:Name="ExecutionProgress"
            Grid.Row="1"
            Margin="0,8,0,0"
            IsIndeterminate="True"
            Height="2"
            Background="#20FFFFFF"
            Foreground="#FF4ECAFF"/>

        <!-- Tool Details / Result -->
        <Border
            x:Name="DetailsBorder"
            Grid.Row="2"
            Margin="0,8,0,0"
            Padding="8"
            CornerRadius="6"
            Background="#15FFFFFF"
            Visibility="Collapsed">

            <ScrollViewer
                MaxHeight="120"
                VerticalScrollBarVisibility="Auto">
                <TextBlock
                    x:Name="DetailsText"
                    Text=""
                    FontSize="12"
                    Foreground="#A0FFFFFF"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
