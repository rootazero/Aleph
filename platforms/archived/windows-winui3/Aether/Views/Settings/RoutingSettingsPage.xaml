<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aleph.Views.Settings.RoutingSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <!-- Cost Strategy -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE909;" FontSize="16"/>
                        <TextBlock Text="Cost Strategy" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Choose how to balance cost and quality for AI model selection."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <RadioButtons x:Name="CostStrategyPicker"
                                  SelectionChanged="CostStrategyPicker_SelectionChanged">
                        <RadioButton Tag="Cheapest">
                            <StackPanel>
                                <TextBlock Text="Cheapest"/>
                                <TextBlock Text="Use the most cost-effective models"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Tag="Balanced" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="Balanced"/>
                                <TextBlock Text="Balance between cost and quality"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Tag="BestQuality">
                            <StackPanel>
                                <TextBlock Text="Best Quality"/>
                                <TextBlock Text="Always use the highest quality models"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </RadioButton>
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Default Model -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8F1;" FontSize="16"/>
                        <TextBlock Text="Default Model" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Select the default model used when no specific routing rule applies."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <ComboBox x:Name="DefaultModelComboBox"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="DefaultModelComboBox_SelectionChanged">
                        <ComboBoxItem Content="Claude 3.5 Sonnet" Tag="claude-3-5-sonnet"/>
                        <ComboBoxItem Content="Claude 3 Opus" Tag="claude-3-opus"/>
                        <ComboBoxItem Content="Claude 3 Haiku" Tag="claude-3-haiku"/>
                        <ComboBoxItem Content="GPT-4o" Tag="gpt-4o"/>
                        <ComboBoxItem Content="GPT-4o Mini" Tag="gpt-4o-mini"/>
                        <ComboBoxItem Content="Gemini 2.0 Flash" Tag="gemini-2.0-flash"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Pipeline Configuration -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE90F;" FontSize="16"/>
                            <TextBlock Text="Model Pipeline" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Text="Enable automatic model chaining for complex tasks"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>

                    <ToggleSwitch Grid.Column="1"
                                  x:Name="PipelineToggle"
                                  OnContent="On"
                                  OffContent="Off"
                                  Toggled="PipelineToggle_Toggled"/>
                </Grid>
            </Border>

            <!-- Task Type Routing -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8D1;" FontSize="16"/>
                        <TextBlock Text="Task Type Routing" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Configure which model handles each task type."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <!-- Routing Rules -->
                    <ItemsControl x:Name="RoutingRulesControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding TaskName}"
                                                   Style="{StaticResource BodyTextBlockStyle}"/>
                                        <TextBlock Text="{Binding TaskDescription}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              SelectedValue="{Binding SelectedModel, Mode=TwoWay}"
                                              SelectedValuePath="Tag"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="RoutingRule_SelectionChanged">
                                        <ComboBoxItem Content="Default" Tag="default"/>
                                        <ComboBoxItem Content="Claude 3.5 Sonnet" Tag="claude-3-5-sonnet"/>
                                        <ComboBoxItem Content="Claude 3 Opus" Tag="claude-3-opus"/>
                                        <ComboBoxItem Content="Claude 3 Haiku" Tag="claude-3-haiku"/>
                                        <ComboBoxItem Content="GPT-4o" Tag="gpt-4o"/>
                                        <ComboBoxItem Content="GPT-4o Mini" Tag="gpt-4o-mini"/>
                                    </ComboBox>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button x:Name="SaveButton"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    IsEnabled="False"
                    Click="SaveButton_Click">
                <TextBlock Text="Save Changes"/>
            </Button>

            <!-- Status InfoBar -->
            <InfoBar x:Name="StatusInfoBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Informational"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
