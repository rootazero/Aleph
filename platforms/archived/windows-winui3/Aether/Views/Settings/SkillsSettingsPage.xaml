<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aleph.Views.Settings.SkillsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24" Spacing="24">

                <!-- Header with Actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE734;" FontSize="20"/>
                        <TextBlock Text="Installed Skills"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="InstallButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="InstallSkill_Click">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            <TextBlock Text="Install"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            x:Name="RefreshButton"
                            Click="RefreshSkills_Click"
                            ToolTipService.ToolTip="Refresh skills list">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                    </Button>
                </Grid>

                <!-- Loading State -->
                <StackPanel x:Name="LoadingState"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            Spacing="8">
                    <ProgressRing IsActive="True" Width="32" Height="32"/>
                    <TextBlock Text="Loading skills..."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Empty State -->
                <Border x:Name="EmptyState"
                        Visibility="Visible"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12"
                        Padding="48">
                    <StackPanel HorizontalAlignment="Center" Spacing="16">
                        <FontIcon Glyph="&#xE734;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Text="No skills installed"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Skills extend Aleph with specialized capabilities.&#x0a;Install skills to enhance your AI assistant."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <Button Style="{StaticResource AccentButtonStyle}"
                                Click="InstallSkill_Click"
                                Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                <TextBlock Text="Install your first skill"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Skills List -->
                <ItemsControl x:Name="SkillsItemsControl" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            Width="40" Height="40"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="8">
                                        <FontIcon Glyph="&#xE734;"
                                                  FontSize="20"
                                                  Foreground="White"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2"/>
                                        <TextBlock Text="{Binding UsageHint}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Delete Button -->
                                    <Button Grid.Column="2"
                                            Click="DeleteSkill_Click"
                                            Tag="{Binding}"
                                            ToolTipService.ToolTip="Delete skill">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Skills Directory Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Skills Directory"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"/>
                            <TextBlock x:Name="SkillsDirectoryText"
                                       Text="%APPDATA%\Aleph\skills"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="OpenSkillsDirectory_Click"
                                ToolTipService.ToolTip="Open in Explorer">
                            <FontIcon Glyph="&#xE838;" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Install Skill Dialog -->
        <ContentDialog x:Name="InstallSkillDialog"
                       Title="Install Skill"
                       PrimaryButtonText="Install"
                       CloseButtonText="Cancel"
                       PrimaryButtonClick="InstallSkillDialog_PrimaryButtonClick">
            <StackPanel Spacing="16" MinWidth="450">
                <!-- Install Method Picker -->
                <RadioButtons x:Name="InstallMethodPicker"
                              Header="Install from"
                              SelectedIndex="0">
                    <RadioButton Content="GitHub URL" Tag="url"/>
                    <RadioButton Content="ZIP File" Tag="zip"/>
                </RadioButtons>

                <!-- URL Input -->
                <StackPanel x:Name="UrlInputPanel" Spacing="4">
                    <TextBlock Text="GitHub Repository URL"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"/>
                    <TextBox x:Name="UrlInputBox"
                             PlaceholderText="https://github.com/username/skill-name"/>
                    <TextBlock Text="Example: https://github.com/anthropics/claude-code-skills"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>

                <!-- ZIP Input -->
                <StackPanel x:Name="ZipInputPanel" Visibility="Collapsed" Spacing="4">
                    <TextBlock Text="ZIP File"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   x:Name="ZipPathText"
                                   Text="No file selected"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button Grid.Column="1"
                                Content="Browse"
                                Margin="8,0,0,0"
                                Click="BrowseZip_Click"/>
                    </Grid>
                    <TextBlock Text="Select a ZIP file containing one or more skills"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </ContentDialog>

        <!-- Delete Confirmation Dialog -->
        <ContentDialog x:Name="DeleteConfirmDialog"
                       Title="Delete Skill"
                       PrimaryButtonText="Delete"
                       CloseButtonText="Cancel"
                       DefaultButton="Close"
                       PrimaryButtonClick="DeleteConfirmDialog_PrimaryButtonClick">
            <TextBlock x:Name="DeleteConfirmText"
                       Text="Are you sure you want to delete this skill?"
                       TextWrapping="Wrap"/>
        </ContentDialog>

        <!-- Status InfoBar -->
        <InfoBar x:Name="StatusInfoBar"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"
                 VerticalAlignment="Top"
                 Margin="24"/>
    </Grid>
</UserControl>
