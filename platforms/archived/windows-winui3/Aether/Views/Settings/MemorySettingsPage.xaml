<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aleph.Views.Settings.MemorySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="24">

            <!-- Storage Usage Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Storage Usage" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" FontSize="24" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <StackPanel>
                                <TextBlock Text="Memory Database" FontWeight="SemiBold"/>
                                <TextBlock
                                    x:Name="MemoryUsageText"
                                    Text="0 MB"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <ProgressBar
                            x:Name="StorageProgressBar"
                            Value="0"
                            Maximum="100"
                            Height="4"/>

                        <TextBlock
                            Text="Includes conversation history, facts, and embeddings."
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Retention Policy Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Retention Policy" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="16">
                        <ComboBox
                            x:Name="RetentionCombo"
                            Header="Keep conversation history for"
                            Width="250"
                            SelectedIndex="2">
                            <ComboBoxItem Content="7 days" Tag="7"/>
                            <ComboBoxItem Content="14 days" Tag="14"/>
                            <ComboBoxItem Content="30 days" Tag="30"/>
                            <ComboBoxItem Content="90 days" Tag="90"/>
                            <ComboBoxItem Content="1 year" Tag="365"/>
                            <ComboBoxItem Content="Forever" Tag="-1"/>
                        </ComboBox>

                        <ToggleSwitch
                            x:Name="AutoCompactToggle"
                            Header="Auto-compact old conversations"
                            IsOn="True"/>

                        <TextBlock
                            Text="Auto-compact compresses old conversations to save space while preserving key facts."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Memory Management Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Memory Management" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Button
                            x:Name="CompactNowButton"
                            Content="Compact Now"
                            Click="CompactNowButton_Click"/>

                        <Button
                            x:Name="ClearHistoryButton"
                            Content="Clear All History"
                            Click="ClearHistoryButton_Click"
                            Style="{ThemeResource AccentButtonStyle}"/>

                        <TextBlock
                            Text="Warning: Clearing history cannot be undone."
                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                            FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Facts Layer Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Facts Layer" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel>
                                <TextBlock Text="Total Facts" FontWeight="SemiBold"/>
                                <TextBlock
                                    x:Name="FactsCountText"
                                    Text="0"
                                    FontSize="24"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Topics" FontWeight="SemiBold"/>
                                <TextBlock
                                    x:Name="TopicsCountText"
                                    Text="0"
                                    FontSize="24"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <Button
                            x:Name="ViewFactsButton"
                            Content="View Facts Browser"
                            Click="ViewFactsButton_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
