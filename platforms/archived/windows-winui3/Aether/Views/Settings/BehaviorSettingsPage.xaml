<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aether.Views.Settings.BehaviorSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16">

            <!-- Output Mode -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8F2;" FontSize="16"/>
                        <TextBlock Text="Output Mode" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Choose how AI responses are displayed in the chat."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <RadioButtons x:Name="OutputModePicker"
                                  SelectionChanged="OutputModePicker_SelectionChanged">
                        <RadioButton Tag="Typewriter" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="Typewriter"/>
                                <TextBlock Text="Characters appear one by one with animation"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Tag="Instant">
                            <StackPanel>
                                <TextBlock Text="Instant"/>
                                <TextBlock Text="Show complete response immediately"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </RadioButton>
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Typing Speed -->
            <Border x:Name="TypingSpeedCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE916;" FontSize="16"/>
                        <TextBlock Text="Typing Speed" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Adjust the speed of typewriter effect (characters per second)."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <Slider x:Name="TypingSpeedSlider"
                                Grid.Column="0"
                                Minimum="10"
                                Maximum="200"
                                Value="50"
                                StepFrequency="5"
                                TickFrequency="10"
                                TickPlacement="Outside"
                                ValueChanged="TypingSpeedSlider_ValueChanged"/>

                        <TextBlock Grid.Column="1"
                                   x:Name="TypingSpeedValue"
                                   Text="50 c/s"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="Slow (10)" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Text="Fast (200)" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- PII Data Cleaning -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72E;" FontSize="16"/>
                            <TextBlock Text="PII Data Cleaning" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Text="Automatically detect and mask sensitive personal information before sending to AI providers."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Master Toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Enable PII Protection" Style="{StaticResource BodyTextBlockStyle}"/>
                            <TextBlock Text="Turn on automatic PII detection and masking"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      x:Name="PiiMasterToggle"
                                      OnContent="On"
                                      OffContent="Off"
                                      IsOn="True"
                                      Toggled="PiiMasterToggle_Toggled"/>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Individual PII Types -->
                    <StackPanel x:Name="PiiOptionsPanel" Spacing="12">

                        <!-- Email Addresses -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Email Addresses"/>
                                <TextBlock Text="Mask email addresses (e.g., j***@example.com)"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1"
                                          x:Name="EmailToggle"
                                          OnContent="On"
                                          OffContent="Off"
                                          IsOn="True"
                                          Toggled="PiiOption_Toggled"/>
                        </Grid>

                        <!-- Phone Numbers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Phone Numbers"/>
                                <TextBlock Text="Mask phone numbers (e.g., ***-***-1234)"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1"
                                          x:Name="PhoneToggle"
                                          OnContent="On"
                                          OffContent="Off"
                                          IsOn="True"
                                          Toggled="PiiOption_Toggled"/>
                        </Grid>

                        <!-- Social Security Numbers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Social Security Numbers"/>
                                <TextBlock Text="Mask SSN patterns (e.g., ***-**-1234)"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1"
                                          x:Name="SsnToggle"
                                          OnContent="On"
                                          OffContent="Off"
                                          IsOn="True"
                                          Toggled="PiiOption_Toggled"/>
                        </Grid>

                        <!-- Credit Card Numbers -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Credit Card Numbers"/>
                                <TextBlock Text="Mask credit card numbers (e.g., ****-****-****-1234)"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1"
                                          x:Name="CreditCardToggle"
                                          OnContent="On"
                                          OffContent="Off"
                                          IsOn="True"
                                          Toggled="PiiOption_Toggled"/>
                        </Grid>

                        <!-- IP Addresses -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="IP Addresses"/>
                                <TextBlock Text="Mask IP addresses (e.g., ***.***.***.123)"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1"
                                          x:Name="IpAddressToggle"
                                          OnContent="On"
                                          OffContent="Off"
                                          IsOn="False"
                                          Toggled="PiiOption_Toggled"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Response Formatting -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A1;" FontSize="16"/>
                        <TextBlock Text="Response Formatting" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Code Syntax Highlighting -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Code Syntax Highlighting"/>
                            <TextBlock Text="Apply syntax highlighting to code blocks"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      x:Name="SyntaxHighlightToggle"
                                      OnContent="On"
                                      OffContent="Off"
                                      IsOn="True"
                                      Toggled="FormattingOption_Toggled"/>
                    </Grid>

                    <!-- Markdown Rendering -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Markdown Rendering"/>
                            <TextBlock Text="Render markdown formatting in responses"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      x:Name="MarkdownToggle"
                                      OnContent="On"
                                      OffContent="Off"
                                      IsOn="True"
                                      Toggled="FormattingOption_Toggled"/>
                    </Grid>

                    <!-- Auto-copy Code -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Show Copy Button on Code Blocks"/>
                            <TextBlock Text="Display a copy button on code snippets"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      x:Name="CodeCopyButtonToggle"
                                      OnContent="On"
                                      OffContent="Off"
                                      IsOn="True"
                                      Toggled="FormattingOption_Toggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button x:Name="SaveButton"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    IsEnabled="False"
                    Click="SaveButton_Click">
                <TextBlock Text="Save Changes"/>
            </Button>

            <!-- Status InfoBar -->
            <InfoBar x:Name="StatusInfoBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Informational"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
