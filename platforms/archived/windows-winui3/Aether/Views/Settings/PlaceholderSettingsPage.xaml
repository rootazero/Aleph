<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aleph.Views.Settings.PlaceholderSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <FontIcon
                x:Name="PageIcon"
                Glyph="&#xE713;"
                FontSize="48"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"/>

            <TextBlock
                x:Name="PageTitle"
                Text="Settings"
                Style="{StaticResource SubtitleTextBlockStyle}"
                HorizontalAlignment="Center"/>

            <TextBlock
                x:Name="PageDescription"
                Text="This section will be implemented in a future update."
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
                MaxWidth="300"/>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0">
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Coming Soon"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="Check for updates to get the latest features."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="12"
                        HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
