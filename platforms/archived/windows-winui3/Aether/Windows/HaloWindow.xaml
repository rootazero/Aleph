<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Aether.Windows.HaloWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aether.ViewModels"
    xmlns:halo="using:Aether.Views.Halo"
    Title="Halo">

    <!-- Transparent background with rounded border -->
    <Border
        x:Name="RootBorder"
        Background="#E0000000"
        CornerRadius="16"
        Padding="20"
        BorderBrush="#40FFFFFF"
        BorderThickness="1">

        <Grid MinWidth="200" MinHeight="100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Halo indicator ring -->
            <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12">
                <!-- Main gradient ring -->
                <Ellipse
                    x:Name="HaloRing"
                    Width="48"
                    Height="48">
                    <Ellipse.Fill>
                        <LinearGradientBrush x:Name="HaloGradient" StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="GradientStart" Color="#FF6B4EFF" Offset="0"/>
                            <GradientStop x:Name="GradientEnd" Color="#FF9B6BFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Thinking/Loading animation ring -->
                <ProgressRing
                    x:Name="ThinkingRing"
                    Width="56"
                    Height="56"
                    IsActive="False"
                    Foreground="#FF6B4EFF"/>

                <!-- Multi-turn indicator badge -->
                <Border
                    x:Name="MultiTurnBadge"
                    Width="16"
                    Height="16"
                    CornerRadius="8"
                    Background="#FF4ECAFF"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,-4,-4"
                    Visibility="Collapsed">
                    <FontIcon
                        Glyph="&#xE8BD;"
                        FontSize="10"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>

                <!-- Agent mode indicator badge -->
                <Border
                    x:Name="AgentBadge"
                    Width="16"
                    Height="16"
                    CornerRadius="8"
                    Background="#FF4E6BFF"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="-4,0,0,-4"
                    Visibility="Collapsed">
                    <FontIcon
                        Glyph="&#xE99A;"
                        FontSize="10"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Content area -->
            <Grid Grid.Row="1">
                <!-- Status text (shown when not streaming/tool) -->
                <TextBlock
                    x:Name="StatusText"
                    Text="Ready"
                    Foreground="White"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    TextAlignment="Center"/>

                <!-- Streaming view (shown during streaming) -->
                <halo:HaloStreamingView
                    x:Name="StreamingView"
                    Visibility="Collapsed"
                    VerticalAlignment="Top"/>

                <!-- Tool execution view (shown during tool execution) -->
                <halo:HaloToolView
                    x:Name="ToolView"
                    Visibility="Collapsed"
                    VerticalAlignment="Top"/>

                <!-- Error message (shown on error) -->
                <Border
                    x:Name="ErrorBorder"
                    Padding="8"
                    CornerRadius="8"
                    Background="#30FF4E4E"
                    VerticalAlignment="Top"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="ErrorText"
                        Foreground="#FFFF6B6B"
                        FontSize="12"
                        TextWrapping="Wrap"
                        MaxWidth="280"
                        HorizontalAlignment="Center"/>
                </Border>

                <!-- Clarification view (shown when clarification needed) -->
                <Border
                    x:Name="ClarificationBorder"
                    Padding="12"
                    CornerRadius="8"
                    Background="#304EFFFF"
                    VerticalAlignment="Top"
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Need clarification"
                            Foreground="#FF4EFFFF"
                            FontSize="13"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"/>
                        <TextBlock
                            x:Name="ClarificationText"
                            Foreground="#E0FFFFFF"
                            FontSize="12"
                            TextWrapping="Wrap"
                            MaxWidth="280"
                            HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
