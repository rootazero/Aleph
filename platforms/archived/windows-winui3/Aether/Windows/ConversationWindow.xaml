<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Aether.Windows.ConversationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aether.ViewModels"
    Title="Aether Conversation">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- Content (Messages/Commands/Topics) -->
            <RowDefinition Height="Auto"/>  <!-- Streaming Indicator -->
            <RowDefinition Height="Auto"/>  <!-- Input Area -->
        </Grid.RowDefinitions>

        <!-- Messages List - visible when DisplayState == Conversation -->
        <ScrollViewer
            x:Name="MessagesScrollViewer"
            Grid.Row="0"
            MinHeight="0"
            VerticalScrollBarVisibility="Auto"
            Padding="16"
            Visibility="{x:Bind ViewModel.IsShowingConversation, Mode=OneWay}">
            <ItemsControl
                x:Name="MessagesContainer"
                ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConversationMessage">
                        <Border
                            Margin="0,8"
                            Padding="12"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Message Header -->
                                <StackPanel
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,0,0,8">
                                    <Border
                                        Width="24"
                                        Height="24"
                                        CornerRadius="12"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                                        <TextBlock
                                            Text="{x:Bind RoleInitial}"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock
                                        Text="{x:Bind RoleDisplay}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"/>
                                    <TextBlock
                                        Text="{x:Bind TimestampDisplay}"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Message Content -->
                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind Content, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Command List - visible when DisplayState == CommandList -->
        <ListView
            x:Name="CommandListView"
            Grid.Row="0"
            MinHeight="0"
            Padding="16"
            SelectionMode="Single"
            Visibility="{x:Bind ViewModel.IsShowingCommands, Mode=OneWay}"
            ItemsSource="{x:Bind ViewModel.FilteredCommands, Mode=OneWay}"
            SelectedIndex="{x:Bind ViewModel.SelectedCommandIndex, Mode=TwoWay}"
            ItemClick="CommandListView_ItemClick"
            IsItemClickEnabled="True">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:CommandItem">
                    <Grid Padding="8,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Command Icon -->
                        <Border
                            Grid.Column="0"
                            Grid.RowSpan="2"
                            Width="32"
                            Height="32"
                            Margin="0,0,12,0"
                            CornerRadius="6"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            VerticalAlignment="Center">
                            <FontIcon
                                Glyph="&#xE756;"
                                FontSize="14"
                                Foreground="White"/>
                        </Border>

                        <!-- Command Name -->
                        <TextBlock
                            Grid.Column="1"
                            Grid.Row="0"
                            FontWeight="SemiBold">
                            <Run Text="/"/><Run Text="{x:Bind Name}"/>
                        </TextBlock>

                        <!-- Command Description -->
                        <TextBlock
                            Grid.Column="1"
                            Grid.Row="1"
                            Text="{x:Bind Description}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Topic List - visible when DisplayState == TopicList -->
        <ListView
            x:Name="TopicListView"
            Grid.Row="0"
            MinHeight="0"
            Padding="16"
            SelectionMode="Single"
            Visibility="{x:Bind ViewModel.IsShowingTopics, Mode=OneWay}"
            ItemsSource="{x:Bind ViewModel.FilteredTopics, Mode=OneWay}"
            SelectedIndex="{x:Bind ViewModel.SelectedTopicIndex, Mode=TwoWay}"
            ItemClick="TopicListView_ItemClick"
            IsItemClickEnabled="True">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TopicItem">
                    <Grid Padding="8,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Topic Icon -->
                        <Border
                            Grid.Column="0"
                            Grid.RowSpan="2"
                            Width="32"
                            Height="32"
                            Margin="0,0,12,0"
                            CornerRadius="6"
                            Background="{ThemeResource SystemAccentColorLight2}"
                            VerticalAlignment="Center">
                            <FontIcon
                                Glyph="&#xE8BD;"
                                FontSize="14"
                                Foreground="White"/>
                        </Border>

                        <!-- Topic Title -->
                        <TextBlock
                            Grid.Column="1"
                            Grid.Row="0"
                            Text="{x:Bind Title}"
                            FontWeight="SemiBold"/>

                        <!-- Topic Description -->
                        <TextBlock
                            Grid.Column="1"
                            Grid.Row="1"
                            Text="{x:Bind Description}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Streaming Indicator -->
        <Border
            x:Name="StreamingIndicator"
            Grid.Row="1"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            Padding="16,8"
            Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ProgressRing
                    IsActive="True"
                    Width="20"
                    Height="20"/>
                <TextBlock
                    Text="Aether is typing..."
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center"/>
                <Button
                    x:Name="StopButton"
                    Content="Stop"
                    Click="StopButton_Click"
                    VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Input Area (macOS style: TextBox + Attachment + Send) -->
        <Border
            Grid.Row="2"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="16">
            <Border.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Clear Conversation" Click="ClearButton_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE74D;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Border.ContextFlyout>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>      <!-- TextBox -->
                    <ColumnDefinition Width="Auto"/>   <!-- Attachment Button -->
                    <ColumnDefinition Width="Auto"/>   <!-- Send Button -->
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="InputTextBox"
                    Grid.Column="0"
                    PlaceholderText="Type a message..."
                    AcceptsReturn="False"
                    TextWrapping="Wrap"
                    MaxHeight="120"
                    KeyDown="InputTextBox_KeyDown"
                    Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Attachment Button (+ icon) -->
                <Button
                    x:Name="AttachButton"
                    Grid.Column="1"
                    Width="36"
                    Height="36"
                    Margin="8,0,0,0"
                    VerticalAlignment="Bottom"
                    ToolTipService.ToolTip="Add attachment">
                    <FontIcon Glyph="&#xE710;" FontSize="16"/>
                </Button>

                <!-- Send Button (arrow up icon only) -->
                <Button
                    x:Name="SendButton"
                    Grid.Column="2"
                    Width="36"
                    Height="36"
                    Margin="4,0,0,0"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="SendButton_Click"
                    IsEnabled="{x:Bind ViewModel.CanSend, Mode=OneWay}"
                    VerticalAlignment="Bottom"
                    ToolTipService.ToolTip="Send message (Enter)">
                    <FontIcon Glyph="&#xE724;" FontSize="16"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
