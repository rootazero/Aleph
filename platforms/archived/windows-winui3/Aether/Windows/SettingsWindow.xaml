<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Aleph.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aleph.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Navigation View -->
        <NavigationView
            x:Name="SettingsNav"
            Grid.Row="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            SelectionChanged="SettingsNav_SelectionChanged">

            <NavigationView.MenuItems>
                <!-- General -->
                <NavigationViewItem Tag="General" x:Uid="NavItem_General">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Providers -->
                <NavigationViewItem Tag="Providers" x:Uid="NavItem_Providers">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Generation -->
                <NavigationViewItem Tag="Generation" x:Uid="NavItem_Generation">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B9;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Routing -->
                <NavigationViewItem Tag="Routing" x:Uid="NavItem_Routing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Shortcuts -->
                <NavigationViewItem Tag="Shortcuts" x:Uid="NavItem_Shortcuts">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE765;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Behavior -->
                <NavigationViewItem Tag="Behavior" x:Uid="NavItem_Behavior">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Memory -->
                <NavigationViewItem Tag="Memory" x:Uid="NavItem_Memory">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Search -->
                <NavigationViewItem Tag="Search" x:Uid="NavItem_Search">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE721;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <!-- MCP -->
                <NavigationViewItem Tag="Mcp" x:Uid="NavItem_MCP">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE912;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Skills -->
                <NavigationViewItem Tag="Skills" x:Uid="NavItem_Skills">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Cowork -->
                <NavigationViewItem Tag="Cowork" x:Uid="NavItem_Cowork">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE902;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Policies -->
                <NavigationViewItem Tag="Policies" x:Uid="NavItem_Policies">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D4;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Content Area -->
            <Frame x:Name="ContentFrame"/>

        </NavigationView>

        <!-- Save Bar (shown when there are unsaved changes) -->
        <Border
            x:Name="SaveBar"
            Grid.Row="1"
            Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
            Padding="16,12"
            Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="StatusMessageText"
                    Grid.Column="0"
                    x:Uid="Settings_UnsavedChanges"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="CancelButton"
                        x:Uid="Common_Cancel"
                        Click="CancelButton_Click"/>
                    <Button
                        x:Name="SaveButton"
                        x:Uid="Common_Save"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
