<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="POC.HaloWindow.ControlWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="POC-1: Halo Window Test">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock
            Grid.Row="0"
            Text="POC-1: No-Focus Halo Window"
            Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Instructions -->
        <TextBlock
            Grid.Row="1"
            TextWrapping="Wrap"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}">
            <Run Text="Test Steps:"/>
            <LineBreak/>
            <Run Text="1. Click 'Show Halo' button"/>
            <LineBreak/>
            <Run Text="2. Open another app (e.g., Notepad) and start typing"/>
            <LineBreak/>
            <Run Text="3. Verify that Halo appears but does NOT steal focus"/>
            <LineBreak/>
            <Run Text="4. Typing should continue in the other app"/>
        </TextBlock>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <Button
                x:Name="ShowHaloButton"
                Content="Show Halo at Cursor"
                Click="ShowHaloButton_Click"
                Style="{StaticResource AccentButtonStyle}"/>

            <Button
                x:Name="HideHaloButton"
                Content="Hide Halo"
                Click="HideHaloButton_Click"/>

            <Button
                x:Name="ShowAtCenterButton"
                Content="Show at Screen Center"
                Click="ShowAtCenterButton_Click"/>
        </StackPanel>

        <!-- Test Input Area -->
        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock Text="Test typing here (focus should stay here when Halo shows):"/>
            <TextBox
                x:Name="TestInput"
                PlaceholderText="Type here to test focus behavior..."
                AcceptsReturn="True"
                TextWrapping="Wrap"
                MinHeight="100"/>
        </StackPanel>

        <!-- Status -->
        <StackPanel Grid.Row="4" Spacing="4">
            <TextBlock Text="Status:" FontWeight="SemiBold"/>
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</Window>
