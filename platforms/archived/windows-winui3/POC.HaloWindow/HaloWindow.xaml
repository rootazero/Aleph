<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="POC.HaloWindow.HaloWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Halo">

    <!-- Transparent background with rounded border -->
    <Border
        Background="#E0000000"
        CornerRadius="12"
        Padding="16"
        BorderBrush="#40FFFFFF"
        BorderThickness="1">

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8">

            <!-- Halo indicator -->
            <Ellipse
                Width="48"
                Height="48"
                HorizontalAlignment="Center">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF6B4EFF" Offset="0"/>
                        <GradientStop Color="#FF9B6BFF" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Status text -->
            <TextBlock
                x:Name="StatusText"
                Text="Listening..."
                Foreground="White"
                FontSize="14"
                HorizontalAlignment="Center"/>

            <!-- Test info -->
            <TextBlock
                Text="POC: No-focus window test"
                Foreground="#80FFFFFF"
                FontSize="10"
                HorizontalAlignment="Center"/>

        </StackPanel>
    </Border>
</Window>
