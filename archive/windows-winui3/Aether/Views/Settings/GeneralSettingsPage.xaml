<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Aether.Views.Settings.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="24">

            <!-- Sound Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Sound" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <ToggleSwitch
                        x:Name="SoundToggle"
                        Header="Sound Effects"
                        IsOn="{x:Bind ViewModel.SoundEnabled, Mode=TwoWay}"/>
                </Border>
            </StackPanel>

            <!-- Startup Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Startup" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <ToggleSwitch
                            x:Name="StartupToggle"
                            Header="Launch at Windows startup"
                            IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}"/>
                        <TextBlock
                            Text="Aether will start automatically when you sign in to Windows."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Language Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Language" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <ComboBox
                        x:Name="LanguageCombo"
                        Header="Language Preference"
                        Width="250"
                        SelectedIndex="0">
                        <ComboBoxItem Content="System Default" Tag="system"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="简体中文" Tag="zh-Hans"/>
                    </ComboBox>
                </Border>
            </StackPanel>

            <!-- Updates Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Updates" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="12">
                        <Button
                            x:Name="CheckUpdatesButton"
                            Content="Check for Updates"
                            Click="CheckUpdatesButton_Click"/>
                        <TextBlock
                            Text="Automatic updates will be available in a future release."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Logs Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Logs" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="ViewLogsButton"
                            Content="View Logs"
                            Click="ViewLogsButton_Click"/>
                        <Button
                            x:Name="OpenConfigButton"
                            Content="Open Config Folder"
                            Click="OpenConfigButton_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- About Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Version:" FontWeight="SemiBold"/>
                            <TextBlock
                                x:Name="VersionText"
                                Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock
                            Text="Aether - System-level AI middleware"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
